@page
@model Pharma_Pulse.Pages.GstSettingsModel

<h2 style="margin-bottom:20px;">GST Settings</h2>

<form method="post">

    <label style="font-weight:600;">GST Percent:</label>

    <input asp-for="GstPercent"
           type="number"
           step="0.1"
           style="width:120px;padding:8px;margin:10px 0;" />

    <button type="submit"
            style="padding:10px 18px;
                   background:green;
                   color:white;
                   border:none;
                   border-radius:8px;">
        Update GST
    </button>

</form>

<hr />

<p>
    <b>Last Updated:</b> @Model.LastUpdated
</p>
