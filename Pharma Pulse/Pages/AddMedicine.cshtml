@page


@model Pharma_Pulse.Pages.AddMedicineModel

@{
    ViewData["HideFooter"] = true;
}

<link rel="stylesheet" href="~/css/addmedicine.css" />

<div class="dashboard-container">

    <!-- Sidebar -->
    <aside class="sidebar">
        <h2 class="sidebar-title">Pharma Pulse</h2>

        <ul class="sidebar-menu">

            <li>
                <a asp-page="/Dashboard" class="menu-link">
                    <span class="icon">🏠</span>
                    <span class="text">Dashboard</span>
                </a>
            </li>

            <li>
                <a asp-page="/TotalMedicine" class="menu-link">
                    <span class="icon">💊</span>
                    <span class="text"> Medicines</span>
                </a>
            </li>

            <li>
                <a asp-page="/AddMedicine" class="menu-link active">
                    <span class="icon">➕</span>
                    <span class="text">Add Medicine</span>
                </a>
            </li>
        </ul>
    </aside>

    <!-- Main Content -->
    <div class="main-content">
        <div class="content-card">

            <div class="card-header">
                <h2>Add New Medicine</h2>
            </div>

            @if (Model.SuccessMessage != null)
            {
                <div class="alert success">
                    @Model.SuccessMessage
                </div>
            }


            <form method="post" class="medicine-form">

                <div class="form-grid">

                    <!-- ✅ Medicine Name -->
                    <div class="form-group">
                        <label>Medicine Name</label>
                        <input asp-for="Medicine.MedicineName" type="text" class="form-input" />
                    </div>

                    <!-- ✅ Category -->
                    <div class="form-group">
                        <label>Category</label>
                        <input asp-for="Medicine.Category" type="text" class="form-input" />
                    </div>

                    <!-- ✅ NEW Batch No -->
                    <div class="form-group">
                        <label>Batch No</label>
                        <input asp-for="Medicine.BatchNo" type="text" class="form-input" />
                    </div>

                    <!-- ✅ NEW MFG Date -->
                    <div class="form-group">
                        <label>MFG Date</label>
                        <input asp-for="Medicine.MfgDate" type="date" class="form-input" />
                    </div>

                    <!-- ✅ NEW HSN/SAC Code -->
                    <div class="form-group">
                        <label>HSN / SAC</label>
                        <input asp-for="Medicine.HsnSac" type="text" class="form-input" />
                    </div>

                    <!-- ✅ Total Stock Units -->
                    <div class="form-group">
                        <label>Total Stock Units</label>
                        <input asp-for="Medicine.StockUnits" type="number" class="form-input" />
                    </div>

                    <!-- ✅ Units Per Strip Field (Hide for Unit Sale) -->
                    <div class="form-group" id="stripField">
                        <label>Units Per Pack (Strip/Box)</label>
                        <input asp-for="Medicine.UnitsPerStrip" type="number" class="form-input" />
                    </div>

                    <!-- ✅ Selling Mode -->
                    <div class="form-group">
                        <label>Selling Mode</label>
                        <select asp-for="Medicine.SellType" class="form-input" id="sellType">
                            <option value="Unit">Unit (Single Item)</option>
                            <option value="Pack">Pack (Strip/Box)</option>
                            <option value="Both">Both</option>
                        </select>
                    </div>

                    <!-- ✅ Low Stock Alert -->
                    <div class="form-group">
                        <label>Low Stock Alert Limit</label>
                        <input asp-for="Medicine.LowStockLimit" type="number" class="form-input" />
                    </div>

                    <!-- ✅ Buying Price -->
                    <div class="form-group">
                        <label>Buying Price</label>
                        <input asp-for="Medicine.BuyingPrice" type="number" step="0.01" class="form-input" />
                    </div>

                    <!-- ✅ Selling Price -->
                    <div class="form-group">
                        <label>Selling Price</label>
                        <input asp-for="Medicine.SellingPrice" type="number" step="0.01" class="form-input" />
                    </div>

                    <!-- ✅ Expiry Date -->
                    <div class="form-group full-width">
                        <label>Expiry Date</label>
                        <input asp-for="Medicine.ExpiryDate" type="date" class="form-input" />
                    </div>

                </div>

                <button type="submit" class="btn-save">
                    ✅ Save Medicine
                </button>

            </form>

        </div>
    </div>
</div>

<!-- ✅ JavaScript (No CSS Change) -->
<script>

    const sellType = document.getElementById("sellType");

    const stripField = document.getElementById("stripField");

    const stripInput = stripField.querySelector("input");

    function toggleStripField() {

        if (sellType.value === "Unit") {

            // Hide Strip Field
            stripField.style.display = "none";

            // Auto set UnitsPerStrip = 1
            stripInput.value = 1;

        }
        else {

            // Show Strip Field
            stripField.style.display = "flex";

        }

    }

    sellType.addEventListener("change", toggleStripField);

    // Run on page load
    toggleStripField();

</script>
