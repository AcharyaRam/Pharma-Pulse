@page
@model Pharma_Pulse.Pages.AddMedicineModel

<link rel="stylesheet" href="~/css/medicine.css" />

<div class="dashboard-container">

    <!-- Sidebar -->
    <div class="sidebar">
        <h2 class="sidebar-title">Pharma Pulse</h2>

        <ul class="sidebar-menu">
            <li><a asp-page="/Dashboard" class="menu-link">🏠 Dashboard</a></li>
            <li><a asp-page="/TotalMedicine" class="menu-link">💊 Medicines</a></li>
            <li><a asp-page="/AddMedicine" class="menu-link active">➕ Add Medicine</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content">

        <div class="content-card">

            <div class="card-header">
                <h2>Add New Medicine</h2>
                <p>Fill all medicine details carefully</p>
            </div>

            <form method="post" class="medicine-form">

                <!-- Medicine Name -->
                <label>Medicine Name</label>
                <input asp-for="Medicine.MedicineName" required />

                <!-- Category -->
                <label>Category</label>
                <input asp-for="Medicine.Category" required />

                <!-- Stock Units -->
                <label>Total Stock Units (Tablets)</label>
                <input asp-for="Medicine.StockUnits" type="number" required />

                <!-- Units Per Strip -->
                <label>Units Per Strip</label>
                <input asp-for="Medicine.UnitsPerStrip" type="number" required />

                <!-- Sell Type -->
                <label>Selling Type</label>
                <select asp-for="Medicine.SellType" required>
                    <option value="Tablet">Tablet Only</option>
                    <option value="Strip">Strip Only</option>
                    <option value="Both">Both (Tablet + Strip)</option>
                </select>

                <!-- Low Stock Limit -->
                <label>Low Stock Alert Limit</label>
                <input asp-for="Medicine.LowStockLimit" type="number" required />

                <!-- Buying Price -->
                <label>Buying Price</label>
                <input asp-for="Medicine.BuyingPrice" type="number" step="0.01" required />

                <!-- Selling Price -->
                <label>Selling Price</label>
                <input asp-for="Medicine.SellingPrice" type="number" step="0.01" required />

                <!-- Expiry Date -->
                <label>Expiry Date</label>
                <input asp-for="Medicine.ExpiryDate" type="date" required />

                <!-- Submit -->
                <button type="submit" class="btn-add">
                    ✅ Save Medicine
                </button>

            </form>

            @if (Model.SuccessMessage != null)
            {
                <p style="color:green; margin-top:15px;">
                    @Model.SuccessMessage
                </p>
            }

        </div>
    </div>
</div>
