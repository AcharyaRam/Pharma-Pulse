@page
@model Pharma_Pulse.Pages.QuickBillingModel

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    body {
        margin: 0;
    }

    .dashboard-container {
        display: flex;
    }

    /* Sidebar */
    .sidebar {
        width: 250px;
        padding: 35px 25px;
        border-top-right-radius: 30px;
        border-bottom-right-radius: 30px;
        box-shadow: 8px 0 40px rgba(0,0,0,0.15);
    }

    .sidebar-title {
        font-size: 26px;
        font-weight: 700;
        color: white;
        margin-bottom: 40px;
    }

    .sidebar-menu {
        list-style: none;
        padding: 0;
    }

        .sidebar-menu li {
            margin-bottom: 18px;
        }

    .menu-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        border-radius: 16px;
        text-decoration: none;
        transition: 0.3s;
    }

        .menu-link:hover {
            background: rgba(255,255,255,0.18);
            transform: translateX(6px);
        }

        .menu-link.active {
            background: white;
            color: #4f46e5;
            font-weight: 600;
        }

    /* Main Content */
    .main-content {
        flex: 1;
        padding: 40px;
    }

    .content-card {
        background: white;
        padding: 25px;
        border-radius: 18px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    h2 {
        margin: 0;
        font-weight: 700;
        color: #1e293b;
    }

    h3 {
        margin-top: 20px;
        color: #334155;
    }

    /* Form Rows */
    .billing-form {
        display: flex;
        gap: 15px;
        margin-bottom: 15px;
    }

    input, select {
        padding: 10px;
        border-radius: 10px;
        border: 1px solid #ddd;
        font-size: 14px;
        width: 100%;
    }

        input:focus, select:focus {
            border-color: #7c3aed;
            outline: none;
            box-shadow: 0 0 0 4px rgba(124,58,237,0.15);
        }

    /* Quantity FIX */
    .qty-box {
        width: 120px !important;
        flex: none !important;
        text-align: center;
    }

    /* Buttons */
    .btn-add {
        background: linear-gradient(135deg,#22c55e,#16a34a);
        color: white;
        border: none;
        padding: 12px 20px;
        border-radius: 15px;
        cursor: pointer;
        font-weight: 500;
        transition: 0.3s;
        white-space: nowrap;
    }

        .btn-add:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(34,197,94,0.3);
        }

    .btn-alert {
        background: linear-gradient(135deg,#6366f1,#8b5cf6);
        color: white;
        border: none;
        padding: 12px 20px;
        border-radius: 15px;
        cursor: pointer;
        font-weight: 500;
        transition: 0.3s;
    }

        .btn-alert:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(139,92,246,0.3);
        }

    /* Delete Button */
    .btn-delete {
        background: linear-gradient(135deg,#ef4444,#dc2626);
        color: white;
        padding: 6px 14px;
        border: none;
        border-radius: 10px;
        cursor: pointer;
    }

    /* Table */
    .sales-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 25px;
    }

        .sales-table th {
            background: #f1f5f9;
            padding: 12px;
        }

        .sales-table td {
            padding: 10px;
            text-align: center;
            border-bottom: 1px solid #eee;
        }

    /* Total */
    .total-box {
        margin-top: 25px;
        font-size: 22px;
        font-weight: 700;
        text-align: right;
        color: #7c3aed;
    }

</style>

<div class="dashboard-container">

    <!-- Sidebar -->
    <div class="sidebar">
        <h2 class="sidebar-title">Pharma Pulse</h2>
        <ul class="sidebar-menu">
            <li><a asp-page="/Dashboard" class="menu-link">🏠 Dashboard</a></li>
            <li><a asp-page="/SalesSummary" class="menu-link">📊 Sales Summary</a></li>
            <li><a asp-page="/QuickBilling" class="menu-link active">💵 Quick Billing</a></li>
            <li><a asp-page="/TotalMedicine" class="menu-link">💊 Medicines</a></li>
            <li><a asp-page="/LowStockAlerts" class="menu-link">⚠ Low Stock Alerts</a></li>
            <li><a asp-page="/ExpiryAlerts" class="menu-link">⏳ Expiry Alerts</a></li>
        </ul>
    </div>

    <!-- Main -->
    <div class="main-content">

        <div class="content-card">

            <div class="card-header">
                <h2>Quick Billing</h2>
                <p><b>Invoice:</b> @Model.InvoiceNumber</p>
            </div>

            <!-- FORM -->
            <form method="post" asp-page-handler="AddItem">

                <h3>Customer Details</h3>

                <div class="billing-form">
                    <input asp-for="CustomerName" placeholder="Enter Customer Name" />
                    <input asp-for="MobileNumber" placeholder="Enter Mobile Number" />
                </div>

                <div class="billing-form">
                    <input asp-for="DoctorName" placeholder="Enter Doctor Name" />
                </div>

                <hr />

                <h3>Add Medicines</h3>

                <div class="billing-form">
                    <select asp-for="SelectedMedicine">
                        <option value="">-- Select Medicine --</option>
                        @foreach (var med in Model.AllMedicines)
                        {
                            <option value="@med.MedicineName">@med.MedicineName</option>
                        }
                    </select>

                    <select asp-for="SellMode">
                        <option value="Tablet">Tablet</option>
                        <option value="Strip">Strip</option>
                    </select>


                    <!-- Quantity Fixed -->
                    <input asp-for="Quantity"
                           class="qty-box"
                           type="number"
                           min="1"
                           value="1" />

                    <button type="submit" class="btn-add">
                        ➕ Add Item
                    </button>

                </div>
            </form>

            <!-- TABLE -->
            <table class="sales-table">
                <thead>
                    <tr>
                        <th>Medicine</th>
                        <th>Qty</th>
                        <th>Price</th>
                        <th>Total</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model.BillItems)
                    {
                        <tr>
                            <td>@item.MedicineName</td>
                            <td>@item.Quantity</td>
                            <td>₹@item.Price.ToString("0.00")</td>
                            <td>₹@item.Total.ToString("0.00")</td>
                            <td>
                                <form method="post" asp-page-handler="DeleteItem">
                                    <input type="hidden" name="medicineName" value="@item.MedicineName" />
                                    <button type="submit" class="btn-delete">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- TOTAL -->
            <div class="total-box">
                Grand Total: ₹@Model.GrandTotal.ToString("0.00")
            </div>

            <!-- ACTION BUTTONS -->
            <div style="margin-top:25px; display:flex; gap:15px;">
                <form method="post" asp-page-handler="CompleteSale">
                    <button type="submit" class="btn-alert">✅ Complete Sale</button>
                </form>

                <form method="post" asp-page-handler="PrintBill">
                    <button type="submit" class="btn-alert">🖨 Print Invoice</button>
                </form>
            </div>

        </div>
    </div>
</div>
