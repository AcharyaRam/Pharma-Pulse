@page
@model Pharma_Pulse.Pages.QuickBillingModel

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Poppins', sans-serif;
        background: #f9fafb;
        margin: 0;
        color: #111827;
    }

    /* ================= SIDEBAR ================= */
    .sidebar {
        width: 75px;
        padding: 30px 12px;
        background: white;
        border-right: 1px solid #e5e7eb;
        position: fixed;
        height: 100vh;
        overflow: hidden;
        transition: 0.3s ease;
        z-index: 10;
    }

        .sidebar:hover {
            width: 240px;
        }

    .sidebar-title {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 30px;
        white-space: nowrap;
        opacity: 1;
        transition: 0.3s;
    }

    .sidebar:not(:hover) .sidebar-title {
        opacity: 0;
    }

    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .sidebar-menu li {
            margin-bottom: 15px;
        }

    .menu-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        border-radius: 10px;
        text-decoration: none;
        color: #374151;
        white-space: nowrap;
        transition: 0.2s;
    }

    .sidebar:not(:hover) .text {
        display: none;
    }

    .sidebar:not(:hover) .menu-link {
        justify-content: center;
    }

    .menu-link:hover {
        background: #f3f4f6;
    }

    .menu-link.active {
        background: rgba(146,185,184,0.25);
        border-left: 4px solid #92b9b8;
        font-weight: 600;
    }

    /* ================= MAIN ================= */
    .main-content {
        margin-left: 95px;
        padding: 30px;
    }

    .content-card {
        background: white;
        padding: 25px;
        border-radius: 16px;
        border: 1px solid #e5e7eb;
    }

    h2 {
        margin: 0;
    }

    hr {
        margin: 20px 0;
        border: none;
        border-top: 1px solid #e5e7eb;
    }

    /* ================= FORM ================= */
    .billing-form {
        display: flex;
        gap: 12px;
        margin-top: 12px;
        align-items: center;
    }

    select, input {
        padding: 10px;
        border-radius: 10px;
        border: 1px solid #ddd;
        width: 100%;
        font-size: 14px;
    }

    .qty-input {
        width: 90px !important;
        text-align: center;
    }

    /* ================= BUTTONS ================= */
    .btn-add, .btn-alert {
        background: #92b9b8;
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
    }

    .btn-delete {
        background: #ef4444;
        color: white;
        padding: 6px 14px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
    }

    /* ================= TABLE ================= */
    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 18px;
    }

    th {
        background: #f3f4f6;
        padding: 10px;
        text-align: left;
    }

    td {
        padding: 10px;
        border-bottom: 1px solid #eee;
    }

    .customer-big .line {
        font-size: 16px;
        margin: 10px 0;
        color: #111827;
        line-height: 1.6;
    }

    .customer-big b {
        font-weight: 600;
        color: #000;
    }

    .customer-big span {
        font-weight: 500;
        color: #374151;
    }



    /* ================= BOX ================= */
    .box {
        margin-top: 18px;
        padding: 15px;
        border-radius: 12px;
        background: #fafafa;
        border: 1px solid #e5e7eb;
    }
</style>

<!-- ================= SIDEBAR ================= -->
<aside class="sidebar">
    <h2 class="sidebar-title">Pharma Pulse</h2>

    <ul class="sidebar-menu">
        <li><a asp-page="/Dashboard" class="menu-link">🏠 <span class="text">Dashboard</span></a></li>
        <li><a asp-page="/SalesSummary" class="menu-link">📊 <span class="text">Sales Summary</span></a></li>
        <li><a asp-page="/QuickBilling" class="menu-link active">💵 <span class="text">Billing</span></a></li>
        <li><a asp-page="/TotalMedicine" class="menu-link">💊 <span class="text">Medicines</span></a></li>
    </ul>
</aside>

<!-- ================= MAIN ================= -->
<div class="main-content">
    <div class="content-card">

        <h2>Billing</h2>
        <p>Invoice: @Model.InvoiceNumber</p>

        <!-- CUSTOMER -->
        <h3>Select Customer</h3>

        <form method="post" asp-page-handler="SelectCustomer">
            <div class="billing-form">

                <select asp-for="SelectedCustomerId" required>
                    <option value="">-- Select Customer --</option>
                    @foreach (var cust in Model.AllCustomers)
                    {
                        <option value="@cust.CustomerId">
                            @cust.CustomerName - @cust.MobileNumber
                        </option>
                    }
                </select>

                <button type="submit" class="btn-add">✔ Select</button>

                <button type="button" class="btn-add"
                        onclick="window.location.href='/AddCustomer'">
                    ➕ Add Customer
                </button>

            </div>
        </form>

        <!-- CUSTOMER PREVIEW -->
        @if (Model.SelectedCustomer != null)
        {
            <div class="box customer-big">
                <h3>Customer Details</h3>

                <!-- Line 1 -->
                <p class="line">
                    <b>@Model.SelectedCustomer.CustomerName</b>
                    <span>(@Model.SelectedCustomer.Gender, @Model.SelectedCustomer.Age yrs)</span>
                    | <b>Mob:</b> @Model.SelectedCustomer.MobileNumber
                </p>

                <!-- Line 2 -->
                <p class="line">
                    <b>City:</b> @Model.SelectedCustomer.City
                    | <b>Type:</b> @Model.SelectedCustomer.CustomerType
                    | <b>Doctor:</b> @Model.SelectedCustomer.DoctorReference
                </p>

                <!-- Optional Line -->
                @if (!string.IsNullOrEmpty(Model.SelectedCustomer.Email) ||
               !string.IsNullOrEmpty(Model.SelectedCustomer.MedicalNotes))
                {
                    <p class="line">
                        @if (!string.IsNullOrEmpty(Model.SelectedCustomer.Email))
                        {
                            <b>Email:</b> @Model.SelectedCustomer.Email
                        }

                        @if (!string.IsNullOrEmpty(Model.SelectedCustomer.MedicalNotes))
                        {
                            <span> | <b>Notes:</b> @Model.SelectedCustomer.MedicalNotes</span>
                        }
                    </p>
                }
            </div>


        }

        <hr />

        <!-- ADD MEDICINES -->
        <form method="post" asp-page-handler="AddItem">

            <h3>Add Medicines</h3>

            <div class="billing-form">

                <select asp-for="SelectedMedicine" id="medicineDropdown">
                    <option value="">-- Select Medicine --</option>
                    @foreach (var med in Model.AllMedicines)
                    {
                        <option value="@med.MedicineName">@med.MedicineName</option>
                    }
                </select>

                <!-- SellMode Only for Both -->
                <select asp-for="SellMode" id="sellModeDropdown" style="display:none;">
                    <option value="Tablet">Unit</option>
                    <option value="Strip">Strip</option>
                </select>

                <input asp-for="Quantity" type="number" min="1" value="1" class="qty-input" />

                <button type="submit" class="btn-add">➕ Add</button>

            </div>
        </form>

        <!-- BILL ITEMS TABLE -->
        <table>
            <thead>
                <tr>
                    <th>Medicine</th>
                    <th>Qty</th>
                    <th>Mode</th>
                    <th>Price</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.BillItems)
                {
                    <tr>
                        <td>@item.MedicineName</td>
                        <td>@item.Quantity</td>
                        <td>@item.SaleMode</td>
                        <td>₹@item.Price</td>
                        <td>₹@item.Total</td>
                        <td>
                            <form method="post" asp-page-handler="DeleteItem">
                                <input type="hidden" name="medicineName" value="@item.MedicineName" />
                                <button class="btn-delete">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- SUMMARY -->
        <div class="box">
            <h3>Bill Summary</h3>

            <p>Subtotal: ₹@Model.SubTotal</p>
            <p>CGST: ₹@Model.CGST</p>
            <p>SGST: ₹@Model.SGST</p>

            <form method="post" asp-page-handler="ApplyDiscount">
                <label>Discount (%)</label>
                <input asp-for="DiscountPercent" min="0" />

                <label>Payment Mode</label>
                <select asp-for="PaymentMode">
                    <option>Cash</option>
                    <option>UPI</option>
                    <option>Card</option>
                    <option>Due</option>
                </select>

                <button type="submit" class="btn-add">Apply</button>
            </form>

            <h2>Grand Total: ₹@Model.GrandTotal</h2>
        </div>

        <!-- COMPLETE -->
        <form method="post" asp-page-handler="CompleteSale">
            <button class="btn-alert" style="margin-top:15px;">
                ✅ Complete Sale
            </button>
        </form>

    </div>
</div>

<!-- SELLTYPE SCRIPT -->
<script>
    const medicineDropdown = document.getElementById("medicineDropdown");
    const sellModeDropdown = document.getElementById("sellModeDropdown");

    const medicineSellTypes = {
    @foreach (var med in Model.AllMedicines)
    {
        <text>"@med.MedicineName": "@med.SellType",</text>
    }
    };

    function toggleSellMode() {
        const selectedMed = medicineDropdown.value;
        const sellType = medicineSellTypes[selectedMed];

        if (!sellType) {
            sellModeDropdown.style.display = "none";
            return;
        }

        if (sellType === "Both") {
            sellModeDropdown.style.display = "block";
        } else {
            sellModeDropdown.style.display = "none";
        }
    }

    medicineDropdown.addEventListener("change", toggleSellMode);
</script>
