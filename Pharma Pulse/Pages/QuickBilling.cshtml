<div class="@(Model.IsReviewMode ? "main-content review-mode" : "main-content")">

    <h2>Billing</h2>
    <p>Invoice: @Model.InvoiceNumber</p>
    <hr />

    <!-- CUSTOMER -->
    <h3>Select Customer</h3>
    <form method="post" asp-page-handler="SelectCustomer">
        <select asp-for="SelectedCustomerId" required>
            <option value="">-- Select Customer --</option>
            @foreach (var cust in Model.AllCustomers)
            {
                <option value="@cust.CustomerId">@cust.FirstName - @cust.MobileNumber</option>
            }
        </select>
        <button type="submit">Select</button>
    </form>

    @if (Model.SelectedCustomer != null)
    {
        <div class="customer-card">
            <div class="customer-card-header">Customer Details</div>
            <div class="customer-grid">
                <div class="item"><label>Name</label><span>@Model.SelectedCustomer.FirstName @Model.SelectedCustomer.Surname</span></div>
                <div class="item"><label>Mobile</label><span>@Model.SelectedCustomer.MobileNumber</span></div>
                <div class="item"><label>Gender</label><span>@Model.SelectedCustomer.Gender</span></div>
                <div class="item"><label>Age</label><span>@Model.SelectedCustomer.Age</span></div>
                <div class="item"><label>City</label><span>@Model.SelectedCustomer.City</span></div>
                <div class="item"><label>Type</label><span>@Model.SelectedCustomer.CustomerType</span></div>
                <div class="item"><label>Doctor</label><span>@Model.SelectedCustomer.DoctorReference</span></div>
                <div class="item full"><label>Notes</label><span>@Model.SelectedCustomer.MedicalNotes</span></div>
            </div>
        </div>
    }

    <hr />

    <!-- ADD MEDICINE -->
    <!-- ADD MEDICINE -->
    <h3>Add Medicine</h3>
    <form method="post" asp-page-handler="AddItem">
        <select asp-for="SelectedMedicine" id="medicineDropdown" required>
            <option value="">-- Select Medicine --</option>
            @foreach (var med in Model.AllMedicines)
            {
                <option value="@med.MedicineName">@med.MedicineName</option>
            }
        </select>

        <select asp-for="SellMode" id="sellModeDropdown" style="display:none;">
            <option value="Unit">Unit</option>
            <option value="Strip">Strip</option>
        </select>

        <input asp-for="Quantity" type="number" min="1" value="1" />
        <button type="submit">Add</button>

        @if (TempData["StockError"] != null)
        {
            <div class="stock-error">
                @TempData["StockError"]
            </div>
        }

    </form>

    <hr />

    <!-- BILL TABLE -->
    <table class="bill-table">
        <thead>
            <tr>
                <th>Qty</th>
                <th>Product Name</th>
                <th>MFG</th>
                <th>HSN</th>
                <th>BATCH</th>
                <th>Mode</th>
                <th>EXP</th>
                <th>MRP</th>
                <th>Total</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.BillItems)
            {
                <tr>
                    <td>@item.Quantity</td>
                    <td>@item.MedicineName</td>
                    <td>@item.MfgDate.ToString("MM/yyyy")</td>
                    <td>@item.HsnSac</td>
                    <td>@item.BatchNo</td>
                    <td>@item.SaleMode</td>
                    <td>@item.ExpiryDate.ToString("MM/yyyy")</td>
                    <td>₹@item.Price</td>
                    <td>₹@item.Total</td>
                    <td>
                        <form method="post" asp-page-handler="DeleteItem">
                            <input type="hidden" name="medicineName" value="@item.MedicineName" />
                            <button class="btn-delete" type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            }

            <tr class="summary-row">
                <td colspan="7"></td>
                <td><b>Subtotal</b></td>
                <td><b>₹@Model.SubTotal</b></td>
                <td></td>
            </tr>
        </tbody>
    </table>

    <!-- NEW COMPACT SUMMARY -->
    <div class="billing-summary">

        <form method="post" asp-page-handler="UpdateBill">

            <div class="bill-row">

                <div class="small-field">
                    <label>Discount (%)</label>
                    <input asp-for="DiscountPercent" type="number" step="0.01" />
                </div>

                <div class="small-field">
                    <label>GST %</label>
                    <select asp-for="SelectedGstPercent">
                        <option value="0">0%</option>
                        <option value="5">5%</option>
                        <option value="12">12%</option>
                        <option value="18">18%</option>
                    </select>
                </div>

                <div class="small-field">
                    <label>Payment Mode</label>
                    <select asp-for="PaymentMode">
                        <option>Cash</option>
                        <option>UPI</option>
                        <option>Card</option>
                        <option>Due</option>
                    </select>
                </div>

                <!-- ✅ Professional Update Button -->
                <button type="submit" class="update-btn">
                    Update Bill
                </button>

            </div>
        </form>



        <div class="amount-section">


            <div class="total-row">
                <span class="total-text">Grand Total :</span>
                <span class="total-price">₹@Model.GrandTotal.ToString("0.00")</span>
            </div>

        </div>



        <div class="action-buttons">
            <form method="post" asp-page-handler="CompleteSale">
                <button type="button" onclick="completeSale()" class="complete-btn">
                    Complete Sale
                </button>
            </form>
            <button type="button" class="print-btn" onclick="printInvoice()">🖨 Print Bill</button>
        </div>

    </div>

</div>

<script>
     const medicineDropdown = document.getElementById("medicineDropdown");
    const sellModeDropdown = document.getElementById("sellModeDropdown");

    const medicineSellTypes = {
    @foreach (var med in Model.AllMedicines)
    {
        <text>"@med.MedicineName": "@med.SellType",</text>
    }
    };

    medicineDropdown.addEventListener("change", function () {

        const type = medicineSellTypes[this.value];

        if (type === "Both") {
            sellModeDropdown.style.display = "block";

            // ✅ Default Select Unit
            sellModeDropdown.value = "Unit";
        }
        else {
            sellModeDropdown.style.display = "none";
        }

    });
</script>

<script>
    function printInvoice(){
        window.print();
    }
</script>


<!-- ================= PRINT BILL ================= -->
<div id="printBill" class="print-bill">

    <div class="bill-header">
        <h2>PHARMA PULSE MEDICAL</h2>
        <p>Near City Hospital, Vadodara, Gujarat</p>
        <p>GSTIN: 24ABCDE1234F1Z5 | DL No: GJ-122345</p>
        <p>Phone: 9999999999</p>
    </div>

    <hr />

    <div class="bill-info">
        <div>
            <b>Invoice No:</b> @Model.InvoiceNumber <br />
            <b>Date:</b> @DateTime.Now.ToString("dd/MM/yyyy hh:mm tt")
        </div>

        <div>
            <b>Customer:</b> @Model.SelectedCustomer?.FirstName @Model.SelectedCustomer?.Surname <br />
            <b>Mobile:</b> @Model.SelectedCustomer?.MobileNumber
        </div>
    </div>

    <table class="invoice-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Medicine</th>
                <th>Batch</th>
                <th>Expiry</th>
                <th>Qty</th>
                <th>MRP</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
            }
            @foreach (var item in Model.BillItems)
            {
                <tr>
                    <td>@i</td>
                    <td>@item.MedicineName</td>
                    <td>@item.BatchNo</td>
                    <td>@item.ExpiryDate.ToString("MM/yy")</td>
                    <td>@item.Quantity</td>
                    <td>@item.Price.ToString("0.00")</td>
                    <td>@item.Total.ToString("0.00")</td>
                </tr>
                i++;
            }
        </tbody>
    </table>

    <div class="totals">
        <p>Subtotal : ₹@Model.SubTotal.ToString("0.00")</p>
        <p>Discount : @Model.DiscountPercent %</p>
        <p>GST (@Model.SelectedGstPercent%) : ₹@Model.GstAmount.ToString("0.00")</p>

        <h2>Net Amount : ₹@Model.GrandTotal.ToString("0.00")</h2>
    </div>

    <div class="sign">
        <p>Pharmacist Signature</p>
    </div>

    <p class="thanks">*** Thank You Visit Again ***</p>

</div>

<script>
    function submitWithScroll(form) {

        // Save scroll before submit
        document.getElementById("scrollPos").value = window.scrollY;

        form.submit();
    }

    window.addEventListener("load", function () {

        let pos = document.getElementById("scrollPos").value;

        if (pos && pos > 0) {
            window.scrollTo(0, pos);
        }
    });
</script>
<script>
    function completeSale() {

        fetch('?handler=CompleteSale', {
            method: 'POST',
            headers: {
                'RequestVerificationToken':
                    document.querySelector('input[name="__RequestVerificationToken"]').value
            }
        })
        .then(response => response.json())
        .then(data => {

            if (data.success) {

                alert(data.message);   // ✅ Sale Saved Successfully!

                // Bill clear
                fetch('?handler=ClearBill', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken':
                            document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                })
                .then(() => {
                    window.location.reload();
                });

            } else {
                alert(data.message);
            }

        })
        .catch(error => {
            alert("Server Error!");
            console.log(error);
        });
    }
</script>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const isReviewMode = document.querySelector(".review-mode");

        if (isReviewMode) {

            // Sab forms block
            document.querySelectorAll("form").forEach(form => {
                form.addEventListener("submit", function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    alert("Review Mode - Editing Disabled");
                });
            });

            // JS buttons block (like CompleteSale)
            document.querySelectorAll("button").forEach(btn => {
                btn.addEventListener("click", function (e) {

                    if (btn.type === "button") {
                        e.preventDefault();
                        e.stopPropagation();
                        alert("Review Mode - Editing Disabled");
                    }
                });
            });

        }

    });
</script>