@page
@model Pharma_Pulse.Pages.QuickBillingModel

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    body {
        margin: 0;
        padding: 0;
        font-family: 'Poppins',sans-serif;
        background: linear-gradient(135deg,#e0f2fe,#f8fafc);
    }

    /* Layout */
    .dashboard-container {
        display: flex;
        width: 100%;
        min-height: 100vh;
    }

    /* Sidebar */

    .sidebar {
        width: 250px;
        padding: 35px 25px;
        margin-top: 0px;
        background: linear-gradient(160deg, #4f46e5, #7c3aed);
        border-radius: 2px;
        box-shadow: 0 25px 60px rgba(0,0,0,0.18);
        position: relative;
        overflow: hidden;
        position: relative;
        z-index: 1;
        height: 900px;
    }

        /* Animated glow */
        .sidebar::before {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(255,255,255,0.2), transparent);
            top: -120px;
            left: -120px;
            animation: rotateGlow 18s linear infinite;
            pointer-events: none;
            z-index: 0;
        }

    @@keyframes rotateGlow {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    /* Sidebar Title */
    .sidebar-title {
        font-size: 26px;
        font-weight: 700;
        color: white;
        margin-bottom: 40px;
        letter-spacing: 1px;
    }

    /* Remove bullets */
    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        /* Menu Items */
        .sidebar-menu li {
            margin-bottom: 18px;
        }

    /* Menu Links */
    .menu-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        border-radius: 16px;
        text-decoration: none;
        color: white;
        font-weight: 500;
        transition: all 0.3s ease;
        position: relative;
        z-index: 2;
    }

        /* Hover */
        .menu-link:hover {
            background: rgba(255,255,255,0.18);
            transform: translateX(6px);
        }

        /* Active Item */
        .menu-link.active {
            background: white;
            color: #4f46e5;
            font-weight: 600;
            box-shadow: 0 10px 25px rgba(0,0,0,0.25);
        }

    /* Main */
    .main-content {
        flex: 1;
        padding: 25px;
    }

    /* Card */
    .content-card {
        background: white;
        padding: 25px;
        border-radius: 18px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    }

    /* Header */
    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    /* Forms */
    .billing-form {
        display: flex;
        gap: 12px;
        margin-bottom: 12px;
        align-items: center;
    }

    input, select {
        padding: 10px;
        border-radius: 10px;
        border: 1px solid #ddd;
        font-size: 14px;
        width: 100%;
    }

    /* ✅ Quantity Small Box */
    .qty-input {
        width: 90px !important;
        text-align: center;
    }

    /* Buttons */
    .btn-add {
        background: linear-gradient(135deg,#22c55e,#16a34a);
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 12px;
        font-weight: 500;
        cursor: pointer;
    }

    .btn-alert {
        background: linear-gradient(135deg,#6366f1,#8b5cf6);
        color: white;
        border: none;
        padding: 10px 18px;
        border-radius: 12px;
        font-weight: 500;
        cursor: pointer;
    }

    .btn-delete {
        background: linear-gradient(135deg,#ef4444,#dc2626);
        color: white;
        padding: 6px 14px;
        border: none;
        border-radius: 8px;
        font-size: 13px;
        cursor: pointer;
    }

    /* Table */
    .sales-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

        .sales-table th {
            background: #f1f5f9;
            padding: 10px;
            font-weight: 600;
        }

        .sales-table td {
            padding: 8px;
            border-bottom: 1px solid #eee;
            text-align: center;
        }

    /* Total */
    .total-box {
        margin-top: 20px;
        font-size: 20px;
        font-weight: 600;
        text-align: right;
        color: #7c3aed;
    }
</style>

<div class="dashboard-container">

    <!-- Sidebar -->
    <div class="sidebar">
        <h2 class="sidebar-title">Pharma Pulse</h2>
        <ul class="sidebar-menu">
            <li><a asp-page="/Dashboard" class="menu-link">🏠 Dashboard</a></li>
            <li><a asp-page="/SalesSummary" class="menu-link">📊 Sales Summary</a></li>
            <li><a asp-page="/QuickBilling" class="menu-link active">💵 Quick Billing</a></li>
            <li><a asp-page="/TotalMedicine" class="menu-link">💊 Medicines</a></li>
            <li><a asp-page="/LowStockAlerts" class="menu-link">⚠ Low Stock Alerts</a></li>
            <li><a asp-page="/ExpiryAlerts" class="menu-link">⏳ Expiry Alerts</a></li>
        </ul>
    </div>

    <!-- Main -->
    <div class="main-content">

        <div class="content-card">

            <div class="card-header">
                <h2>Quick Billing</h2>
                <p><b>Invoice:</b> @Model.InvoiceNumber</p>
            </div>

            <form method="post" asp-page-handler="AddItem">

                <h3>Customer Details</h3>
                <div class="billing-form">
                    <input asp-for="CustomerName" placeholder="Enter Customer Name" />
                    <input asp-for="MobileNumber" placeholder="Enter Mobile Number" />
                </div>

                <hr />

                <h3>Add Medicines</h3>
                <div class="billing-form">
                    <select asp-for="SelectedMedicine">
                        <option value="">-- Select Medicine --</option>
                        @foreach (var med in Model.AllMedicines)
                        {
                            <option value="@med.MedicineName">@med.MedicineName</option>
                        }
                    </select>

                    <!-- ✅ Small Quantity Box -->
                    <input asp-for="Quantity"
                           type="number"
                           min="1"
                           value="1"
                           class="qty-input" />

                    <button type="submit" class="btn-add">
                        ➕ Add Item
                    </button>
                </div>
            </form>

            <table class="sales-table">
                <thead>
                    <tr>
                        <th>Medicine</th>
                        <th>Qty</th>
                        <th>Price</th>
                        <th>Total</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.BillItems)
                    {
                        <tr>
                            <td>@item.MedicineName</td>
                            <td>@item.Quantity</td>
                            <td>₹@item.Price.ToString("0.00")</td>
                            <td>₹@item.Total.ToString("0.00")</td>
                            <td>
                                <form method="post" asp-page-handler="DeleteItem">
                                    <input type="hidden" name="medicineName" value="@item.MedicineName" />
                                    <button type="submit" class="btn-delete">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="total-box">
                Grand Total: ₹@Model.GrandTotal.ToString("0.00")
            </div>

            <div style="margin-top:20px;display:flex;gap:12px;">
                <form method="post" asp-page-handler="CompleteSale">
                    <button type="submit" class="btn-alert">✅ Complete Sale</button>
                </form>

                <form method="post" asp-page-handler="PrintBill">
                    <button type="submit" class="btn-alert">🖨 Print Invoice</button>
                </form>
            </div>

        </div>

    </div>
</div>
