@page
@model Pharma_Pulse.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="~/css/dashboard.css" />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="dashboard-wrapper">

    <aside class="sidebar">
        <h2 class="sidebar-title">Pharma Pulse</h2>

        <ul class="sidebar-menu">

            <li>
                <a asp-page="/Dashboard" class="menu-link active">
                    <span class="icon">🏠</span>
                    <span class="text">Dashboard</span>
                </a>
            </li>

            <li>
                <a asp-page="/SalesSummary" class="menu-link">
                    <span class="icon">📊</span>
                    <span class="text">Sales Summary</span>
                </a>
            </li>

            <li>
                <a asp-page="/QuickBilling" class="menu-link">
                    <span class="icon">💵</span>
                    <span class="text">Quick Billing</span>
                </a>
            </li>

            <li>
                <a asp-page="/TotalMedicine" class="menu-link">
                    <span class="icon">💊</span>
                    <span class="text">Medicines</span>
                </a>
            </li>

            <li>
                <a asp-page="/LowStockAlerts" class="menu-link">
                    <span class="icon">⚠</span>
                    <span class="text">Low Stock Alerts</span>
                </a>
            </li>

            <li>
                <a asp-page="/ExpiryAlerts" class="menu-link">
                    <span class="icon">⏳</span>
                    <span class="text">Expiry Alerts</span>
                </a>
            </li>

            <li>
                <a asp-page="/Login" class="menu-link">
                    <span class="icon">→</span>
                    <span class="text">Logout</span>
                </a>
            </li>

        </ul>
    </aside>


    <!-- Main Content -->
    <div class="main-content">

        <div class="dashboard-header">
            <h2>Pharmacist Dashboard</h2>
            <p>Welcome back, Pharmacist</p>
        </div>

        <!-- Top Cards -->
        <div class="stats-cards">
            <div class="card green">
                <h3>Total Medicines</h3>
                <p>@Model.TotalMedicineCount</p>
            </div>

            <div class="card orange">
                <h3>Low Stock Alerts</h3>
                <p>@Model.LowStockCount</p>
            </div>

            <div class="card red">
                <h3>Expiry Alerts</h3>
                <p>@Model.ExpiryCount Items</p>
            </div>

            <div class="card blue">
                <h3>Sales Today</h3>
                <p>₹@Model.SalesToday</p>
            </div>
        </div>

        <!-- Grid -->
        <div class="dashboard-grid">

            <!-- Left -->
            <div class="left-section">

                <div class="box">
                    <h3>Available Medicines</h3>
                    <table>
                        <thead>
                            <tr>
                                <th>Medicine</th>
                                <th>Category</th>
                                <th>Stock</th>
                                <th>Expiry</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var med in Model.Medicines)
                            {
                                <tr>
                                    <td>@med.MedicineName</td>
                                    <td>@med.Category</td>
                                    <td>@med.StockUnits</td>
                                    <td>@med.ExpiryDate.ToShortDateString()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="box">
                    <h3>Today's Sales Summary</h3>
                    <p><b>Total Sales:</b> ₹@Model.SalesToday</p>
                    <p><b>Total Bills:</b> @Model.TotalBillsToday</p>
                    <p><b>Top Seller:</b> @Model.TopSellerToday</p>
                </div>

            </div>

            <!-- Right -->
            <div class="right-section">

                <div class="quick-box">
                    <h3>Quick Billing</h3>
                    <p>Create a new bill quickly</p>
                    <button onclick="window.location.href='/QuickBilling'">
                        Start Billing
                    </button>
                </div>

                <div class="box alert">
                    <h3>Low Stock Alerts</h3>
                    @if (Model.LowestStockMedicine != null)
                    {
                        <p><b>@Model.LowestStockMedicine.MedicineName</b> - Only @Model.LowestStockMedicine.StockUnits left!</p>
                    }
                    else
                    {
                        <p>No low stock medicines found.</p>
                    }
                </div>

                <div class="box alert-red">
                    <h3>Expiry Alerts (@Model.ExpiryCount)</h3>
                    @if (Model.NearestExpiryMedicine != null)
                    {
                        <p><b>@Model.NearestExpiryMedicine.MedicineName</b> - Expiring Soon!</p>
                    }
                    else
                    {
                        <p>No expiry medicines found.</p>
                    }
                </div>

            </div>

        </div>

    </main>

</div>
