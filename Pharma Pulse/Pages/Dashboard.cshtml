@page
@model Pharma_Pulse.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="~/css/dashboard.css" />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="dashboard-wrapper">

    <!-- Sidebar -->
    <aside class="sidebar">
        <h2 class="sidebar-title">Pharma Pulse</h2>

        <ul class="sidebar-menu">
            <li>
                <a asp-page="/Dashboard" class="menu-link active">
                    <span class="icon">🏠</span>
                    <span class="text">Dashboard</span>
                </a>
            </li>

            <li>
                <a asp-page="/QuickBilling" class="menu-link">
                    <span class="icon">💵</span>
                    <span class="text">Quick Billing</span>
                </a>
            </li>

            <li>
                <a asp-page="/SalesSummary" class="menu-link">
                    <span class="icon">📊</span>
                    <span class="text">Sales Summary</span>
                </a>
            </li>

            <li>
                <a asp-page="/TotalMedicine" class="menu-link">
                    <span class="icon">💊</span>
                    <span class="text">Medicines</span>
                </a>
            </li>

            <li>
                <a asp-page="/TotalCustomers" class="menu-link">
                    <span class="icon">👤</span>
                    <span class="text">Customers</span>
                </a>
            </li>

            <li>
                <a asp-page="/LowStockAlerts" class="menu-link">
                    <span class="icon">⚠</span>
                    <span class="text">Low Stock Alerts</span>
                </a>
            </li>

            <li>
                <a asp-page="/ExpiryAlerts" class="menu-link">
                    <span class="icon">⏳</span>
                    <span class="text">Expiry Alerts</span>
                </a>
            </li>

            <li>
                <a asp-page="/Login" class="menu-link">
                    <span class="icon">→</span>
                    <span class="text">Logout</span>
                </a>
            </li>
        </ul>
    </aside>


    <!-- Main Content -->
    <div class="main-content">

        <!-- Header -->
        <div class="dashboard-header">
            <h2>Dashboard</h2>
        </div>

        <!-- Top Cards -->
        <div class="stats-cards">

            <div class="card">
                <h3>Total Medicines</h3>
                <p>@Model.TotalMedicineCount</p>
            </div>

            <div class="card">
                <h3>Low Stock Alerts</h3>
                <p>@Model.LowStockCount</p>
            </div>

            <div class="card">
                <h3>Expiry Alerts</h3>
                <p>@Model.ExpiryCount</p>
            </div>

            <div class="card">
                <h3>Sales Today</h3>
                <p>₹@Model.SalesToday</p>
            </div>

            <div class="card">
                <h3>Profit Today</h3>
                <p>0</p>
            </div>

        </div>


        <!-- Grid Layout -->
        <div class="dashboard-grid">

            <!-- LEFT = Add Customer -->
            <div class="left-section">

                <div class="box">
                    <h3>Add Customer</h3>
                    <form method="post" asp-page-handler="SaveCustomer" class="customer-form">

                        <!-- Row 1 -->
                        <div class="form-row">
                            <div>
                                <label>First Name *</label>
                                <input asp-for="Customer.FirstName" required />
                            </div>

                            <div>
                                <label>Last Name *</label>
                                <input asp-for="Customer.Surname" required />
                            </div>
                        </div>

                        <!-- Row 2 -->
                        <div class="form-row">
                            <div>
                                <label>Mobile Number *</label>
                                <input asp-for="Customer.MobileNumber" required />
                            </div>

                            <div>
                                <label>GST Number</label>
                                <input asp-for="Customer.GSTNumber" placeholder="Optional" />
                            </div>
                        </div>

                        <!-- Row 3 (4 Fields) -->
                        <div class="form-row four-fields">

                            <div>
                                <label>DOB</label>
                                <input asp-for="Customer.DateOfBirth"
                                       type="date"
                                       id="dobField"
                                       onchange="calculateAge()" />
                            </div>

                            <div>
                                <label>Age *</label>
                                <input asp-for="Customer.Age"
                                       type="number"
                                       id="ageField"
                                       required />
                            </div>

                            <div>
                                <label>Gender</label>
                                <select asp-for="Customer.Gender">
                                    <option value="">Select</option>
                                    <option>Male</option>
                                    <option>Female</option>
                                    <option>Other</option>
                                </select>
                            </div>

                            <div>
                                <label>Customer Type</label>
                                <select asp-for="Customer.CustomerType">
                                    <option>Walk-in</option>
                                    <option>Regular</option>
                                    <option>Doctor Reference</option>
                                </select>
                            </div>

                        </div>

                        <!-- Row 4 -->
                        <div class="form-row">
                            <div>
                                <label>City / Address</label>
                                <input asp-for="Customer.City" />
                            </div>

                            <div>
                                <label>Doctor Name</label>
                                <input asp-for="Customer.DoctorReference" />
                            </div>
                        </div>

                        <!-- Save Button -->
                        <button type="submit" class="save-btn small-btn">
                            Save Customer
                        </button>

                    </form>

                   
                </div>
            </div>


            <!-- RIGHT SECTION -->
            <div class="right-section">

                <!-- Quick Billing -->
                <div class="quick-box">
                    <h3>Quick Billing</h3>
                    <p>Create a new bill quickly</p>

                    <button onclick="window.location.href='/QuickBilling'">
                        Start Billing
                    </button>
                </div>

                <!-- Top Selling Medicines -->
                <div class="card">
                    <h2>Top Selling Medicines</h2>

                    <div class="medicine">
                        <span class="rank">1</span>
                        <span class="name">Paracetamol</span>
                        <span class="price">₹1,020</span>
                    </div>

                    <div class="medicine">
                        <span class="rank">2</span>
                        <span class="name">Azithromycin</span>
                        <span class="price">₹920</span>
                    </div>

                    <div class="medicine">
                        <span class="rank">3</span>
                        <span class="name">Neurobion Plus</span>
                        <span class="price">₹870</span>
                    </div>

                </div>

            </div>

        </div>


        <!-- Revenue Chart -->
        <div class="revenue-section">

            <div class="revenue-header">
                <h2>Last 15 Days Revenue</h2>
                <span class="sub">Daily income overview</span>
            </div>

            <canvas id="revenueChart"></canvas>

        </div>

    </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const revenueLabels = @Html.Raw(Json.Serialize(Model.Days));
    const revenueData = @Html.Raw(Json.Serialize(Model.Revenue));

    const ctx = document.getElementById('revenueChart');

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: revenueLabels,
            datasets: [{
                data: revenueData,
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            plugins: { legend: { display: false } },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        callback: value => '₹' + value
                    }
                }
            }
        }
    });

    function calculateAge() {
        let dob = document.getElementById("dobField").value;
        if (!dob) return;

        let birthDate = new Date(dob);
        let today = new Date();

        let age = today.getFullYear() - birthDate.getFullYear();
        let monthDiff = today.getMonth() - birthDate.getMonth();

        if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
            age--;
        }

        document.getElementById("ageField").value = age;
    }
</script>
