@page
@model Pharma_Pulse.Pages.LowStockAlertsModel

@{
    ViewData["Title"] = "LowStockAlerts";
}

<link rel="stylesheet" href="~/css/medicine.css" />

<div class="dashboard-container">

    <!-- LEFT SIDEBAR -->
    <div class="sidebar">
        <ul>
            
            <li><a asp-page="/Dashboard">🏠 Dashboard</a></li>

            <li><a asp-page="">📊 Sales Summary</a></li>

            <li><a asp-page="">💵 Quick Billing</a></li>

            <li>
                <a asp-page="/TotalMedicine">💊 Medicines</a>
            </li>

            <li class="active">
                <a asp-page="/LowStockAlerts">⚠ Low Stock Alerts</a>
            </li>

            <li>
                <a asp-page="/ExpiryAlerts">⏳ Expiry Alerts</a>
            </li>
        </ul>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">

        <div class="breadcrumb">
            Dashboard / Low Stock Alerts
        </div>

        <div class="content-card">

            <div class="card-header">
                <h2>Low Stock Medicines</h2>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>Medicine Name</th>
                        <th>Category</th>
                        <th>Stock</th>
                        <th>Expiry Date</th>
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var med in Model.LowStockMedicines)
                    {
                        <tr>
                            <td>@med.MedicineName</td>
                            <td>@med.Category</td>
                            <td style="color:red; font-weight:bold;">
                                @med.Stock
                            </td>
                            <td>@med.ExpiryDate.ToShortDateString()</td>
                            <td>
                                <span style="background:red;color:white;padding:5px 10px;border-radius:10px;">
                                    Low Stock
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>

    </div>

</div>
