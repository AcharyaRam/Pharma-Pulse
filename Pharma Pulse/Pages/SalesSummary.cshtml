@page
@model Pharma_Pulse.Pages.SalesSummaryModel

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>

    body {
        margin: 0;
        font-family: 'Poppins', sans-serif;
        background: linear-gradient(135deg, #c7d2fe, #eef2ff);
    }

    /* Layout */
    .dashboard-container {
        display: flex;
    }

    /* Sidebar Container */
    .sidebar {
        width: 250px;
        background: linear-gradient(160deg, #4f46e5, #7c3aed);
        padding: 35px 25px;
        border-top-right-radius: 30px;
        border-bottom-right-radius: 30px;
        box-shadow: 8px 0 40px rgba(0,0,0,0.15);
        position: relative;
        overflow: hidden;
    }

        /* Soft animated glow background */
        .sidebar::before {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(255,255,255,0.15), transparent);
            top: -100px;
            left: -100px;
            animation: rotateGlow 12s linear infinite;
        }

    @@keyframes rotateGlow {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    /* Title */
    .sidebar-title {
        font-size: 28px;
        font-weight: 700;
        color: white;
        margin-bottom: 40px;
        letter-spacing: 1px;
        animation: slideDown 0.6s ease;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Remove bullets */
    .sidebar-menu {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        /* Menu Items */
        .sidebar-menu li {
            margin-bottom: 18px;
        }

    /* Links */
    .menu-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        border-radius: 16px;
        color: white;
        text-decoration: none;
        font-weight: 500;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        /* Hover effect */
        .menu-link:hover {
            background: rgba(255,255,255,0.15);
            transform: translateX(6px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

        /* Active item (Quick Billing style white pill) */
        .menu-link.active {
            background: white;
            color: #4f46e5;
            font-weight: 600;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            transform: scale(1.03);
        }

        /* Ripple effect on click */
        .menu-link:active {
            transform: scale(0.97);
        }

    /* Smooth appearance animation */
    .sidebar-menu li {
        animation: fadeSlide 0.6s ease forwards;
        opacity: 0;
    }

        .sidebar-menu li:nth-child(1) {
            animation-delay: 0.1s;
        }

        .sidebar-menu li:nth-child(2) {
            animation-delay: 0.2s;
        }

        .sidebar-menu li:nth-child(3) {
            animation-delay: 0.3s;
        }

        .sidebar-menu li:nth-child(4) {
            animation-delay: 0.4s;
        }

        .sidebar-menu li:nth-child(5) {
            animation-delay: 0.5s;
        }

        .sidebar-menu li:nth-child(6) {
            animation-delay: 0.6s;
        }

    @@keyframes fadeSlide {
        from {
            opacity: 0;
            transform: translateX(-15px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }


    .menu-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 15px;
        border-radius: 14px;
        text-decoration: none;
        color: white;
        font-weight: 500;
        margin-bottom: 12px;
        transition: 0.3s;
    }

        .menu-link:hover {
            background: rgba(255,255,255,0.2);
        }

        .menu-link.active {
            background: white;
            color: #4f46e5;
            font-weight: 600;
        }

    /* ===== MAIN CONTENT ===== */
    .main-content {
        flex: 1;
        padding: 40px;
    }

    /* Card */
    .content-card {
        background: white;
        padding: 35px;
        border-radius: 30px;
        box-shadow: 0 30px 70px rgba(0,0,0,0.08);
    }

    /* Header */
    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

        .card-header h2 {
            font-weight: 600;
        }

    /* Dropdown */
    .report-select {
        padding: 12px;
        border-radius: 12px;
        border: 1px solid #ddd;
        transition: 0.3s;
    }

        .report-select:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99,102,241,0.1);
            outline: none;
        }

    /* Summary Cards */
    .sales-cards {
        display: flex;
        gap: 20px;
        margin-bottom: 35px;
    }

    .sales-box {
        flex: 1;
        padding: 25px;
        border-radius: 20px;
        color: white;
        transition: 0.3s ease;
    }

        .sales-box:hover {
            transform: translateY(-6px);
        }

        .sales-box h3 {
            margin: 0 0 10px;
            font-weight: 500;
        }

        .sales-box p {
            font-size: 24px;
            font-weight: 600;
            margin: 0;
        }

    .green {
        background: linear-gradient(135deg, #16a34a, #22c55e);
    }

    .blue {
        background: linear-gradient(135deg, #2563eb, #3b82f6);
    }

    .red {
        background: linear-gradient(135deg, #dc2626, #ef4444);
    }

    /* Table */
    .sales-table {
        width: 100%;
        border-collapse: collapse;
        border-radius: 15px;
        overflow: hidden;
    }

        .sales-table th {
            background: #f3f4f6;
            padding: 12px;
            font-weight: 600;
            text-align: center;
        }

        .sales-table td {
            padding: 12px;
            border-bottom: 1px solid #eee;
            text-align: center;
        }

        .sales-table tr:hover {
            background: #f9fafb;
        }

    .profit {
        font-weight: bold;
        color: #16a34a;
    }

    .table-title {
        font-weight: 600;
        margin-bottom: 15px;
    }

</style>

<div class="dashboard-container">

    <!-- Sidebar -->
    <div class="sidebar">
        <h2 class="sidebar-title">Pharma Pulse</h2>

        <ul class="sidebar-menu">
            <li><a asp-page="/Dashboard" class="menu-link">🏠 Dashboard</a></li>
            <li><a asp-page="/SalesSummary" class="menu-link active">📊 Sales Summary</a></li>
            <li><a asp-page="/QuickBilling" class="menu-link">💵 Quick Billing</a></li>
            <li><a asp-page="/TotalMedicine" class="menu-link">💊 Medicines</a></li>
            <li><a asp-page="/LowStockAlerts" class="menu-link">⚠ Low Stock Alerts</a></li>
            <li><a asp-page="/ExpiryAlerts" class="menu-link">⏳ Expiry Alerts</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content">

        <div class="content-card">

            <div class="card-header">
                <h2>Sales Summary Report</h2>

                <form method="get">
                    <select name="ReportType"
                            onchange="this.form.submit()"
                            class="report-select">

                        <option value="Daily" selected="@(Model.ReportType == "Daily")">Daily Report</option>
                        <option value="Monthly" selected="@(Model.ReportType == "Monthly")">Monthly Report</option>
                        <option value="Yearly" selected="@(Model.ReportType == "Yearly")">Yearly Report</option>

                    </select>
                </form>
            </div>

            <div class="sales-cards">

                <div class="sales-box green">
                    <h3>Total Sales (@Model.ReportType)</h3>
                    <p>₹@Model.TotalSales.ToString("0.00")</p>
                </div>

                <div class="sales-box blue">
                    <h3>Total Profit (@Model.ReportType)</h3>
                    <p>₹@Model.TotalProfit.ToString("0.00")</p>
                </div>

                <div class="sales-box red">
                    <h3>Total Loss (@Model.ReportType)</h3>
                    <p>₹0.00</p>
                </div>

            </div>

            <h3 class="table-title">Sales Breakdown</h3>

            <table class="sales-table">
                <thead>
                    <tr>
                        <th>Medicine</th>
                        <th>Qty Sold</th>
                        <th>Total Amount</th>
                        <th>Profit</th>
                        <th>Date</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var sale in Model.FilteredSales)
                    {
                        <tr>
                            <td>@sale.MedicineName</td>
                            <td>@sale.QuantitySold</td>
                            <td>₹@sale.TotalAmount.ToString("0.00")</td>
                            <td class="profit">₹@sale.Profit.ToString("0.00")</td>
                            <td>@sale.SaleDate.ToShortDateString()</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>

    </div>
</div>
