@page
@model Pharma_Pulse.Pages.ExpiryAlertsModel

@{
    ViewData["Title"] = "Expiry Alerts";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/medicine.css" />
<link rel="stylesheet" href="~/css/Expirealert.css" />

<div class="dashboard-container">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <h2 class="sidebar-title">Pharma Pulse</h2>

        <ul class="sidebar-menu">

            <li>
                <a asp-page="/Dashboard" class="menu-link">
                    <i data-lucide="layout-dashboard" class="icon"></i>
                    <span class="text">Dashboard</span>
                </a>
            </li>

            <li>
                <a asp-page="/QuickBilling" class="menu-link">
                    <span class="icon rupee-icon">₹</span>
                    <span class="text">Quick Billing</span>
                </a>
            </li>

            <li>
                <a asp-page="/SalesSummary" class="menu-link">
                    <i data-lucide="bar-chart-3" class="icon"></i>
                    <span class="text">Sales Summary</span>
                </a>
            </li>

            <li>
                <a asp-page="/TotalMedicine" class="menu-link">
                    <i data-lucide="pill" class="icon"></i>
                    <span class="text">Medicines</span>
                </a>
            </li>

            <li>
                <a asp-page="/TotalCustomers" class="menu-link">
                    <i data-lucide="users" class="icon"></i>
                    <span class="text">Customers</span>
                </a>
            </li>

            <li>
                <a asp-page="/LowStockAlerts" class="menu-link">
                    <i data-lucide="alert-triangle" class="icon"></i>
                    <span class="text">Low Stock Alerts</span>
                </a>
            </li>

            <li>
                <a asp-page="/ExpiryAlerts" class="menu-link active">
                    <i data-lucide="alarm-clock" class="icon"></i>
                    <span class="text">Expiry Alerts</span>
                </a>
            </li>
            <li>
                <a asp-page="/Profile" class="menu-link">
                    <i data-lucide="user-cog" class="icon"></i>
                    <span class="text">Profile</span>
                </a>
            </li>


            <li>
                <a asp-page="/Login" class="menu-link">
                    <i data-lucide="log-out" class="icon"></i>
                    <span class="text">Logout</span>
                </a>
            </li>

        </ul>
    </aside>

    <!-- MAIN CONTENT -->
    <div class="main-content">

        <div class="content-card">

            <!-- Header -->
            <div class="card-header">
                <h2>Expiry Alert Medicines</h2>
            </div>

            <!-- ✅ Search Bar -->
            <form method="get" class="search-bar">

                <input type="hidden" name="pageNumber" value="1" />

                <div class="search-input">
                    <span class="search-icon">🔍</span>

                    <input type="text"
                           name="search"
                           value="@Model.SearchTerm"
                           placeholder="Search medicine name or category..." />

                    <button type="submit" class="btn-search">
                        Search
                    </button>
                </div>
            </form>

            <!-- ✅ Table -->
            <table class="sales-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Batch No</th>
                        <th>Expiry</th>
                        <th>Stock</th>
                        <th>Low Limit</th>
                        <th>Buy Cost₹</th>
                        <th>Sell Cost₹</th>
                        <th>HSN</th>
                        <th>Mode</th>

                        <!-- Status -->
                        <th>Status</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var med in Model.ExpiryMedicines)
                    {
                        <tr class="fade-row">

                            <td>@med.MedicineName</td>
                            <td>@med.Category</td>
                            <td>@med.BatchNo</td>

                            <!-- Expiry Highlight -->
                            <td class="@(med.ExpiryDate < DateTime.Now
                                        ? "date-expired"
                                        : "date-soon")">
                                @med.ExpiryDate.ToString("MM/yyyy")
                            </td>

                            <td>@med.StockUnits</td>
                            <td>@med.LowStockLimit</td>

                            <td>₹@med.BuyingPrice</td>
                            <td>₹@med.SellingPrice</td>

                            <td>@med.HsnSac</td>
                            <td>@med.SellType</td>

                            <!-- ✅ Status Badge (Only 2 Cases) -->
                            <td>
                                @if (med.ExpiryDate < DateTime.Now)
                                {
                                    <span class="badge expired-badge">
                                        ❌ Expired
                                    </span>
                                }
                                else
                                {
                                    <span class="badge soon-badge">
                                        ⏳ Expiring Soon
                                    </span>
                                }
                            </td>

                        </tr>
                    }
                </tbody>
            </table>

            <!-- ✅ Pagination -->
            <div class="pagination">

                @if (Model.CurrentPage > 1)
                {
                    <a class="page-btn"
                       asp-page="/ExpiryAlerts"
                       asp-route-pageNumber="@(Model.CurrentPage - 1)"
                       asp-route-search="@Model.SearchTerm">
                        ⬅ Previous
                    </a>
                }

                <span class="page-info">
                    Page @Model.CurrentPage of @Model.TotalPages
                </span>

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a class="page-btn"
                       asp-page="/ExpiryAlerts"
                       asp-route-pageNumber="@(Model.CurrentPage + 1)"
                       asp-route-search="@Model.SearchTerm">
                        Next ➡
                    </a>
                }

            </div>

        </div>

    </div>

</div>
