@page
@model Pharma_Pulse.Pages.ProfileModel
@{
    ViewData["Title"] = "Profile";
}
<link rel="stylesheet" href="~/css/profile.css" />
<link rel="stylesheet" href="~/css/medicine.css" />

<div class="dashboard-container">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <h2 class="sidebar-title">Pharma Pulse</h2>
        <ul class="sidebar-menu">
            <li>
                <a asp-page="/Dashboard" class="menu-link">
                    <i data-lucide="layout-dashboard" class="icon"></i>
                    <span class="text">Dashboard</span>
                </a>
            </li>
            <li>
                <a asp-page="/QuickBilling" class="menu-link">
                    <i data-lucide="receipt" class="icon"></i>
                    <span class="text">Quick Billing</span>
                </a>
            </li>
            <li>
                <a asp-page="/SalesSummary" class="menu-link">
                    <i data-lucide="bar-chart-3" class="icon"></i>
                    <span class="text">Sales Summary</span>
                </a>
            </li>
            <li>
                <a asp-page="/TotalMedicine" class="menu-link">
                    <i data-lucide="pill" class="icon"></i>
                    <span class="text">Medicines</span>
                </a>
            </li>
            <li>
                <a asp-page="/TotalCustomers" class="menu-link">
                    <i data-lucide="users" class="icon"></i>
                    <span class="text">Customers</span>
                </a>
            </li>
            <li>
                <a asp-page="/LowStockAlerts" class="menu-link">
                    <i data-lucide="alert-triangle" class="icon"></i>
                    <span class="text">Low Stock Alerts</span>
                </a>
            </li>
            <li>
                <a asp-page="/ExpiryAlerts" class="menu-link">
                    <i data-lucide="alarm-clock" class="icon"></i>
                    <span class="text">Expiry Alerts</span>
                </a>
            </li>
            <li>
                <a asp-page="/Profile" class="menu-link active">
                    <i data-lucide="user-cog" class="icon"></i>
                    <span class="text">Profile</span>
                </a>
            </li>
            <li>
                <a asp-page="/Login" class="menu-link">
                    <i data-lucide="log-out" class="icon"></i>
                    <span class="text">Logout</span>
                </a>
            </li>
        </ul>
    </aside>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        <h1 class="page-title">Profile</h1>

        @if (TempData["ProfileSuccess"] != null)
        {
            <div class="alert alert-success" style="margin-bottom:15px;">
                @TempData["ProfileSuccess"]
            </div>
        }

        <div class="profile-grid">

            <!-- LEFT COLUMN -->
            <div class="left-section">

                <!-- Pharmacy Info -->
                <div class="card">
                    <h2>Pharmacy Information</h2>

                    <!-- VIEW MODE -->
                    <div id="viewMode">
                        <div class="info-row">
                            <span>Pharmacy Name</span>
                            <strong>@Model.Pharmacy.PharmacyName</strong>
                        </div>
                        <div class="info-row">
                            <span>Owner Name</span>
                            <strong>@Model.Pharmacy.OwnerName</strong>
                        </div>
                        <div class="info-row">
                            <span>Mobile</span>
                            <strong>@Model.Pharmacy.MobileNumber</strong>
                        </div>
                        <div class="info-row">
                            <span>Email</span>
                            <strong>@Model.Pharmacy.Email</strong>
                        </div>
                        <div class="info-row">
                            <span>GST No.</span>
                            <strong>@Model.Pharmacy.GSTNumber</strong>
                        </div>
                        <div class="info-row">
                            <span>Drug License</span>
                            <strong>@Model.Pharmacy.DrugLicenseNo</strong>
                        </div>
                        <div class="info-row">
                            <span>Address</span>
                            <strong>@Model.Pharmacy.Address</strong>
                        </div>
                        <button class="blue-btn" onclick="enableEdit()">Edit Info</button>
                    </div>

                    <!-- EDIT MODE -->
                    <form method="post"
                          asp-page-handler="SaveProfile"
                          id="profileForm"
                          style="display:none;"
                          onsubmit="saveProfile(event)">

                        <input type="hidden" asp-for="Pharmacy.Id" />

                        <div class="info-row">
                            <span>Pharmacy Name</span>
                            <input asp-for="Pharmacy.PharmacyName" class="form-input" />
                        </div>
                        <div class="info-row">
                            <span>Owner Name</span>
                            <input asp-for="Pharmacy.OwnerName" class="form-input" />
                        </div>
                        <div class="info-row">
                            <span>Mobile</span>
                            <input asp-for="Pharmacy.MobileNumber" class="form-input" />
                        </div>
                        <div class="info-row">
                            <span>Email</span>
                            <input asp-for="Pharmacy.Email" class="form-input" />
                        </div>
                        <div class="info-row">
                            <span>GST No.</span>
                            <input asp-for="Pharmacy.GSTNumber" class="form-input" />
                        </div>
                        <div class="info-row">
                            <span>Drug License</span>
                            <input asp-for="Pharmacy.DrugLicenseNo" class="form-input" />
                        </div>
                        <div class="info-row">
                            <span>Address</span>
                            <input asp-for="Pharmacy.Address" class="form-input" />
                        </div>

                        <div style="margin-top:15px;">
                            <button type="submit" id="saveBtn" class="green-btn">
                                <span class="btn-text">Save Profile</span>
                                <span class="btn-loader" style="display:none;">Saving...</span>
                            </button>
                            <button type="button" class="outline-btn" onclick="cancelEdit()">Cancel</button>
                        </div>
                    </form>
                </div>

               

            <!-- RIGHT COLUMN -->
            <div class="right-section">

                <!-- Subscription -->
                <div class="card">
                    <h2>Subscription & Plan</h2>
                    <div class="info-row">
                        <span>Current Plan</span>
                        <strong>@Model.Pharmacy.PlanName</strong>
                    </div>
                    <div class="info-row">
                        <span>Billing Cycle</span>
                        <strong>Monthly</strong>
                    </div>
                    <div class="info-row">
                        <span>Plan Price</span>
                        <strong>₹@Model.Pharmacy.PlanPrice / Month</strong>
                    </div>
                    <div class="info-row">
                        <span>Valid Till</span>
                        <strong>@Model.Pharmacy.PlanValidTill.ToString("dd MMM yyyy")</strong>
                    </div>
                    <div class="info-row">
                        <span>Status</span>
                        <span class="status">@(Model.Pharmacy.IsActive ? "Active" : "Inactive")</span>
                    </div>
              
                </div>

            </div>
        </div>
    </div>
</div>

<!-- ================= UPGRADE PLAN MODAL ================= -->
<div class="modal fade" id="upgradeModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3>Select Your Plan</h3>
                
            </div>
            <div class="row text-center">

                <!-- BASIC -->
                <div class="col-md-4 mb-3">
                    <div class="plan-card">
                        <h4>Basic</h4>
                        <h2 class="price">₹499<span>/month</span></h2>
                        <ul>
                            <li>✔ Billing</li>
                            <li>✔ Stock Management</li>
                            <li>✔ Basic Reports</li>
                        </ul>
                    </div>
                </div>

                <!-- PRO -->
                <div class="col-md-4 mb-3">
                    <div class="plan-card popular">
                        <div class="badge-popular">Most Popular</div>
                        <h4>Pro</h4>
                        <h2 class="price">₹999<span>/month</span></h2>
                        <ul>
                            <li>✔ Billing</li>
                            <li>✔ GST Reports</li>
                            <li>✔ Expiry Alerts</li>
                        </ul>
                        <button class="btn btn-success w-100 select-plan"
                                data-plan="Pro"
                                data-price="999">
                            Current Plan
                        </button>
                    </div>
                </div>

                <!-- ENTERPRISE -->
                <div class="col-md-4 mb-3">
                    <div class="plan-card">
                        <h4>Enterprise</h4>
                        <h2 class="price">₹1999<span>/month</span></h2>
                        <ul>
                            <li>✔ All Features</li>
                            <li>✔ Multi Store</li>
                            <li>✔ Priority Support</li>
                        </ul>
                        <button class="btn btn-outline-success w-100 select-plan"
                                data-plan="Enterprise"
                                data-price="1999">
                            Upgrade
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- Toast Notification -->
<div id="toast" class="custom-toast">
    <span id="toastMessage">Saved Successfully!</span>
</div>

<script>
    lucide.createIcons();
</script>

<script>
    // ================= UPGRADE PLAN =================
    document.querySelectorAll(".select-plan").forEach(button => {
        button.addEventListener("click", function () {
            const plan = this.getAttribute("data-plan");
            const price = this.getAttribute("data-price");

            fetch('?handler=UpgradePlan', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ plan: plan, price: parseInt(price) })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert("Plan upgraded to " + plan + " successfully!");
                    window.location.reload();
                }
            })
            .catch(err => {
                alert("Error upgrading plan!");
            });
        });
    });

    // ================= SAVE PROFILE =================
    function saveProfile(e) {
        e.preventDefault();
        const form = document.getElementById("profileForm");
        const formData = new FormData(form);

        fetch('?handler=SaveProfile', {
            method: 'POST',
            headers: {
                'RequestVerificationToken':
                    document.querySelector('input[name="__RequestVerificationToken"]').value
            },
            body: formData
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                alert("Profile saved successfully!");
                window.location.reload();
            }
        })
        .catch(err => {
            alert("Error saving profile!");
        });
    }

    // ================= EDIT / CANCEL =================
    function enableEdit() {
        document.getElementById("viewMode").style.display = "none";
        document.getElementById("profileForm").style.display = "block";
    }

    function cancelEdit() {
        document.getElementById("viewMode").style.display = "block";
        document.getElementById("profileForm").style.display = "none";
    }
</script>