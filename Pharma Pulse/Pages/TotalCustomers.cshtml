@page
@model Pharma_Pulse.Pages.TotalCustomersModel
@{
    ViewData["Title"] = "Total Customers";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/customer.css" />

<div class="dashboard-container">

    <aside class="sidebar">
        <h2 class="sidebar-title">Pharma Pulse</h2>

        <ul class="sidebar-menu">
            <li>
                <a asp-page="/Dashboard" class="menu-link">
                    <i data-lucide="layout-dashboard" class="icon"></i>
                    <span class="text">Dashboard</span>
                </a>
            </li>

            <li>
                <a asp-page="/QuickBilling" class="menu-link">
                    <span class="icon rupee-icon">₹</span>
                    <span class="text">Quick Billing</span>
                </a>
            </li>

            <li>
                <a asp-page="/SalesSummary" class="menu-link active">
                    <i data-lucide="bar-chart-3" class="icon"></i>
                    <span class="text">Sales Summary</span>
                </a>
            </li>

            <li>
                <a asp-page="/TotalMedicine" class="menu-link">
                    <i data-lucide="pill" class="icon"></i>
                    <span class="text">Medicines</span>
                </a>
            </li>

            <li>
                <a asp-page="/TotalCustomers" class="menu-link">
                    <i data-lucide="users" class="icon"></i>
                    <span class="text">Customers</span>
                </a>
            </li>

            <li>
                <a asp-page="/LowStockAlerts" class="menu-link">
                    <i data-lucide="alert-triangle" class="icon"></i>
                    <span class="text">Low Stock Alerts</span>
                </a>
            </li>

            <li>
                <a asp-page="/ExpiryAlerts" class="menu-link">
                    <i data-lucide="alarm-clock" class="icon"></i>
                    <span class="text">Expiry Alerts</span>
                </a>
            </li>
            <li>
                <a asp-page="/Profile" class="menu-link">
                    <i data-lucide="user-cog" class="icon"></i>
                    <span class="text">Profile</span>
                </a>
            </li>


            <li>
                <a asp-page="/Login" class="menu-link">
                    <i data-lucide="log-out" class="icon"></i>
                    <span class="text">Logout</span>
                </a>
            </li>
        </ul>
    </aside>

    <div class="main-content">
        <div class="content-card">

            <div class="card-header">
                <h2>Total Customers</h2>
                <button type="button" class="btn-add" id="openAddCustomer">+ Add Customer</button>
            </div>

            <form method="get" class="search-bar">
                <div class="search-input">
                    <input type="text" name="search" value="@Model.SearchTerm"
                           placeholder="Customer name & Mobile Number" />
                    <button type="submit" class="btn-search">Search</button>
                </div>
            </form>

            <table class="sales-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Mobile</th>
                        <th>Gender</th>
                        <th>Age</th>
                        <th>City</th>
                        <th>Type</th>
                        <th>Email</th>
                        <th>Doctor Ref</th>
                        <th>Notes</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var cust in Model.Customers)
                    {
                        <tr>
                            <td>@cust.FirstName @cust.Surname</td>
                            <td>@cust.MobileNumber</td>
                            <td>@cust.Gender</td>
                            <td>@cust.Age</td>
                            <td>@cust.City</td>
                            <td>@cust.CustomerType</td>
                            <td>@cust.Email</td>
                            <td>@cust.DoctorReference</td>
                            <td>@cust.MedicalNotes</td>
                            <td>
                                <button type="button" class="btn-view"
                                        onclick="openPreview(
                                        '@cust.CustomerId',
                                        '@cust.FirstName',
                                        '@cust.Surname',
                                        '@cust.MobileNumber',
                                        '@cust.Gender',
                                        '@cust.Age',
                                        '@cust.City',
                                        '@cust.CustomerType',
                                        '@cust.Email',
                                        '@cust.DoctorReference',
                                        '@cust.MedicalNotes'
                                    )">
                                    View
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>


<!-- ADD / EDIT MODAL -->
<div class="modal-overlay" id="customerModal">
    <div class="modal-box">

        <div class="modal-header">
            <h2 id="modalTitle">Add Customer</h2>
            <span class="close-btn" id="closeModal">&times;</span>
        </div>

        <form method="post" asp-page-handler="SaveCustomer" class="customer-form">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Customer.CustomerId" id="customerIdField" />

            <div class="form-row">
                <div>
                    <label>First Name *</label>
                    <input asp-for="Customer.FirstName" required />
                </div>
                <div>
                    <label>Middle Name</label>
                    <input asp-for="Customer.MiddleName" />
                </div>
                <div>
                    <label>Surname *</label>
                    <input asp-for="Customer.Surname" required />
                </div>
            </div>

            <div class="form-row">
                <div>
                    <label>Mobile *</label>
                    <input asp-for="Customer.MobileNumber" required />
                </div>
                <div>
                    <label>Email</label>
                    <input asp-for="Customer.Email" />
                </div>
                <div>
                    <label>GST</label>
                    <input asp-for="Customer.GSTNumber" />
                </div>
            </div>

            <div class="form-row">
                <div>
                    <label>Gender</label>
                    <select asp-for="Customer.Gender">
                        <option value="">Select</option>
                        <option>Male</option>
                        <option>Female</option>
                        <option>Other</option>
                    </select>
                </div>
                <div>
                    <label>DOB</label>
                    <input asp-for="Customer.DateOfBirth" type="date" id="dobField" onchange="calculateAge()" />
                </div>
                <div>
                    <label>Age *</label>
                    <input asp-for="Customer.Age" type="number" id="ageField" required />
                </div>
            </div>

            <div class="form-row">
                <div>
                    <label>City</label>
                    <input asp-for="Customer.City" />
                </div>
                <div>
                    <label>Customer Type</label>
                    <select asp-for="Customer.CustomerType">
                        <option>Walk-in</option>
                        <option>Regular</option>
                        <option>Doctor Reference</option>
                    </select>
                </div>
            </div>

            <label>Doctor Name</label>
            <input asp-for="Customer.DoctorReference" />

            <label>Notes</label>
            <input asp-for="Customer.MedicalNotes" />

            <button type="submit" class="save-btn" id="saveBtn">Save Customer</button>
        </form>

    </div>
</div>


<!-- PREVIEW MODAL -->
<div class="preview-overlay" id="previewModal">
    <div class="preview-box">
        <div class="preview-header">
            <h3>Customer Details</h3>
            <div>
                <button class="btn-edit" onclick="editCustomer()">Edit</button>
                <span onclick="closePreview()" class="close-btn">&times;</span>
            </div>
        </div>

        <div class="preview-grid">
            <div><label>Name</label><span id="p_name"></span></div>
            <div><label>Mobile</label><span id="p_mobile"></span></div>
            <div><label>Gender</label><span id="p_gender"></span></div>
            <div><label>Age</label><span id="p_age"></span></div>
            <div><label>City</label><span id="p_city"></span></div>
            <div><label>Type</label><span id="p_type"></span></div>
            <div><label>Email</label><span id="p_email"></span></div>
            <div><label>Doctor</label><span id="p_doctor"></span></div>
            <div class="full"><label>Notes</label><span id="p_notes"></span></div>
        </div>
    </div>
</div>


<script>
    let currentCustomerId = 0;

    const modal = document.getElementById("customerModal");
    const openBtn = document.getElementById("openAddCustomer");
    const closeBtn = document.getElementById("closeModal");

    modal.style.display = "none";

    openBtn.onclick = () => {
        resetForm();
        modal.style.display = "flex";
    };

    closeBtn.onclick = () => modal.style.display = "none";

    function openPreview(id, first, surname, mobile, gender, age, city, type, email, doctor, notes) {
        currentCustomerId = id;
        document.getElementById("p_name").innerText = first + " " + surname;
        document.getElementById("p_mobile").innerText = mobile;
        document.getElementById("p_gender").innerText = gender;
        document.getElementById("p_age").innerText = age;
        document.getElementById("p_city").innerText = city;
        document.getElementById("p_type").innerText = type;
        document.getElementById("p_email").innerText = email;
        document.getElementById("p_doctor").innerText = doctor;
        document.getElementById("p_notes").innerText = notes;
        document.getElementById("previewModal").style.display = "flex";
    }

    function closePreview() {
        document.getElementById("previewModal").style.display = "none";
    }

    function editCustomer() {
        closePreview();
        document.getElementById("customerIdField").value = currentCustomerId;

        let nameParts = document.getElementById("p_name").innerText.split(" ");
        document.querySelector("[name='Customer.FirstName']").value = nameParts[0];
        document.querySelector("[name='Customer.Surname']").value = nameParts[1] || "";

        document.querySelector("[name='Customer.MobileNumber']").value = document.getElementById("p_mobile").innerText;
        document.querySelector("[name='Customer.Gender']").value = document.getElementById("p_gender").innerText;
        document.querySelector("[name='Customer.Age']").value = document.getElementById("p_age").innerText;
        document.querySelector("[name='Customer.City']").value = document.getElementById("p_city").innerText;
        document.querySelector("[name='Customer.CustomerType']").value = document.getElementById("p_type").innerText;
        document.querySelector("[name='Customer.Email']").value = document.getElementById("p_email").innerText;
        document.querySelector("[name='Customer.DoctorReference']").value = document.getElementById("p_doctor").innerText;
        document.querySelector("[name='Customer.MedicalNotes']").value = document.getElementById("p_notes").innerText;

        document.getElementById("modalTitle").innerText = "Edit Customer";
        document.getElementById("saveBtn").innerText = "Update Customer";

        modal.style.display = "flex";
    }

    function resetForm() {
        document.getElementById("customerIdField").value = 0;
        document.getElementById("modalTitle").innerText = "Add Customer";
        document.getElementById("saveBtn").innerText = "Save Customer";
        document.querySelector("form").reset();
    }

    function calculateAge() {
        let dob = document.getElementById("dobField").value;
        if (!dob) return;
        let birthDate = new Date(dob);
        let today = new Date();
        let age = today.getFullYear() - birthDate.getFullYear();
        let monthDiff = today.getMonth() - birthDate.getMonth();
        if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) age--;
        document.getElementById("ageField").value = age;
    }
</script>