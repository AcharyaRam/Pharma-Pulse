@page
@model Pharma_Pulse.Pages.TotalCustomersModel
@{
    ViewData["Title"] = "Total Customers";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/customer.css" />

<div class="dashboard-container">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <h2 class="sidebar-title">Pharma Pulse</h2>

        <ul class="sidebar-menu">

            <li>
                <a asp-page="/Dashboard" class="menu-link active">
                    <span class="icon">🏠</span>
                    <span class="text">Dashboard</span>
                </a>
            </li>

            <li>
                <a asp-page="/SalesSummary" class="menu-link">
                    <span class="icon">📊</span>
                    <span class="text">Sales Summary</span>
                </a>
            </li>

            <li>
                <a asp-page="/QuickBilling" class="menu-link">
                    <span class="icon">💵</span>
                    <span class="text">Quick Billing</span>
                </a>
            </li>

            <li>
                <a asp-page="/TotalMedicine" class="menu-link">
                    <span class="icon">💊</span>
                    <span class="text">Medicines</span>
                </a>
            </li>

            <li>
                <a asp-page="/TotalCustomers" class="menu-link active">
                    <span class="icon">👤</span>
                    <span class="text">Customers</span>
                </a>
            </li>

            <li>
                <a asp-page="/LowStockAlerts" class="menu-link">
                    <span class="icon">⚠</span>
                    <span class="text">Low Stock Alerts</span>
                </a>
            </li>

            <li>
                <a asp-page="/ExpiryAlerts" class="menu-link">
                    <span class="icon">⏳</span>
                    <span class="text">Expiry Alerts</span>
                </a>
            </li>

            <li>
                <a asp-page="/Login" class="menu-link">
                    <span class="icon">→</span>
                    <span class="text">Logout</span>
                </a>
            </li>

        </ul>
    </aside>

    <!-- MAIN CONTENT -->
    <div class="main-content">

        <div class="content-card">

            <!-- Header -->
            <div class="card-header">
                <h2>Total Customers</h2>

                <button onclick="location.href='@Url.Page("/AddCustomer")'"
                        class="btn-add">
                    + Add Customer
                </button>
            </div>

            <!-- Search -->
            <form method="get" class="search-bar">
                <input type="text"
                       name="search"
                       value="@Model.SearchTerm"
                       placeholder="🔍 Search customer name or mobile..." />

                <button type="submit" class="btn-search">
                    Search
                </button>
            </form>

            <!-- Table -->
            <table class="sales-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Mobile</th>
                        <th>Gender</th>
                        <th>Age</th>
                        <th>City</th>
                        <th>Type</th>
                        <th>Email</th>
                        <th>Doctor Ref</th>
                        <th>Notes</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var cust in Model.Customers)
                    {
                        <tr>
                            <td>@cust.FirstName</td>
                            <td>@cust.MobileNumber</td>
                            <td>@cust.Gender</td>
                            <td>@cust.Age</td>
                            <td>@cust.City</td>
                            <td>@cust.CustomerType</td>
                            <td>@cust.Email</td>
                            <td>@cust.DoctorReference</td>
                            <td>@cust.MedicalNotes</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>
