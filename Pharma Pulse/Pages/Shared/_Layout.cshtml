<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Pharma_Pulse</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Pharma_Pulse.styles.css" asp-append-version="true" />
</head>

<body>

    <!-- ✅ NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow">
            <div class="container">

                <a class="navbar-brand d-flex align-items-center" asp-page="/Login">
                    <img src="~/images/logo.png" alt="Pharma Pulse Logo" class="nav-logo" />
                </a>

            </div>
        </nav>
    </header>


    <!-- ✅ MAIN CONTENT (Flex Grow Area) -->
    <main class="page-wrapper p-0 m-0">
        @RenderBody()
    </main>



    <!-- ✅ FOOTER ALWAYS BOTTOM -->
    <footer class="site-footer">
        <div class="container">
            &copy; 2026 - Pharma_Pulse -
            <a asp-page="/Privacy">Privacy</a>
        </div>
    </footer>


    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
