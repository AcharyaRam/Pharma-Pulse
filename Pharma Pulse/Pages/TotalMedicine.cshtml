@page
@model Pharma_Pulse.Pages.TotalMedicineModel

@{
    ViewData["Title"] = "TotalMedicines";
}

<link rel="stylesheet" href="~/css/medicine.css" />

<div class="dashboard-container">

    <!-- LEFT SIDEBAR -->
    <div class="sidebar">
        <h2 class="sidebar-title">Pharma Pulse</h2>

        <ul class="sidebar-menu">
            <li><a asp-page="/Dashboard" class="menu-link">🏠 Dashboard</a></li>
            <li><a asp-page="/SalesSummary" class="menu-link">📊 Sales Summary</a></li>
            <li><a asp-page="/QuickBilling" class="menu-link">💵 Quick Billing</a></li>

            <li>
                <a asp-page="/TotalMedicine" class="menu-link active">
                    💊 Medicines
                </a>
            </li>

            <li><a asp-page="/LowStockAlerts" class="menu-link">⚠ Low Stock Alerts</a></li>
            <li><a asp-page="/ExpiryAlerts" class="menu-link">⏳ Expiry Alerts</a></li>
        </ul>
    </div>


    <!-- MAIN CONTENT -->
    <div class="main-content">

        <div class="content-card">

            <!-- Header -->
            <div class="card-header">
                <h2>Available Medicines</h2>

                <button onclick="location.href='@Url.Page("/AddMedicine")'"
                        class="btn-add">
                    + Add Medicine
                </button>
            </div>

            <!-- ✅ Search Form -->
            <form method="get" class="table-top">

                <!-- Search Input -->
                <input type="text"
                       name="searchTerm"
                       value="@Model.SearchTerm"
                       placeholder="🔍 Search medicines..." />

                <!-- Showing Info -->
                <div class="entries">
                    Showing @Model.Medicines.Count of @Model.TotalCount Medicines
                </div>

            </form>


            <!-- Table -->
            <table>
                <thead>
                    <tr>
                        <th>Medicine Name</th>
                        <th>Category</th>
                        <th>Stock</th>
                        <th>Expiry Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var med in Model.Medicines)
                    {
                        <tr>
                            <td>@med.MedicineName</td>
                            <td>@med.Category</td>
                            <td>@med.Stock</td>
                            <td>@med.ExpiryDate.ToShortDateString()</td>
                            <td>
                                <button class="btn-edit">Edit</button>
                                <button class="btn-delete">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>


            <!-- ✅ Pagination -->
            <div class="pagination">

                @if (Model.CurrentPage > 1)
                {
                    <a class="page-btn"
                       asp-page="/TotalMedicine"
                       asp-route-pageNumber="@(Model.CurrentPage - 1)"
                       asp-route-searchTerm="@Model.SearchTerm">
                        ⬅ Previous
                    </a>
                }

                <span class="page-info">
                    Page @Model.CurrentPage of @Model.TotalPages
                </span>

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a class="page-btn"
                       asp-page="/TotalMedicine"
                       asp-route-pageNumber="@(Model.CurrentPage + 1)"
                       asp-route-searchTerm="@Model.SearchTerm">
                        Next ➡
                    </a>
                }

            </div>



        </div>
    </div>
</div>
