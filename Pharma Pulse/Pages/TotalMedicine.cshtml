@page
@model Pharma_Pulse.Pages.TotalMedicineModel
@{
    ViewData["Title"] = "TotalMedicines";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/medicine.css" />

<div class="dashboard-container">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <h2 class="sidebar-title">Pharma Pulse</h2>
        <ul class="sidebar-menu">
            <li>
                <a asp-page="/Dashboard" class="menu-link">
                    <i data-lucide="layout-dashboard" class="icon"></i>
                    <span class="text">Dashboard</span>
                </a>
            </li>

            <li>
                <a asp-page="/QuickBilling" class="menu-link">
                    <span class="icon rupee-icon">₹</span>
                    <span class="text">Quick Billing</span>
                </a>
            </li>

            <li>
                <a asp-page="/SalesSummary" class="menu-link">
                    <i data-lucide="bar-chart-3" class="icon"></i>
                    <span class="text">Sales Summary</span>
                </a>
            </li>

            <li>
                <a asp-page="/TotalMedicine" class="menu-link active">
                    <i data-lucide="pill" class="icon"></i>
                    <span class="text">Medicines</span>
                </a>
            </li>

            <li>
                <a asp-page="/TotalCustomers" class="menu-link">
                    <i data-lucide="users" class="icon"></i>
                    <span class="text">Customers</span>
                </a>
            </li>

            <li>
                <a asp-page="/LowStockAlerts" class="menu-link">
                    <i data-lucide="alert-triangle" class="icon"></i>
                    <span class="text">Low Stock Alerts</span>
                </a>
            </li>

            <li>
                <a asp-page="/ExpiryAlerts" class="menu-link">
                    <i data-lucide="alarm-clock" class="icon"></i>
                    <span class="text">Expiry Alerts</span>
                </a>
            </li>
            <li>
                <a asp-page="/Profile" class="menu-link">
                    <i data-lucide="user-cog" class="icon"></i>
                    <span class="text">Profile</span>
                </a>
            </li>

            <li>
                <a asp-page="/Login" class="menu-link">
                    <i data-lucide="log-out" class="icon"></i>
                    <span class="text">Logout</span>
                </a>
            </li>
        </ul>
    </aside>

    <div class="main-content">
        <div class="content-card">

            <div class="card-header">
                <h2>Total Medicines</h2>

                <div style="display:flex; align-items:center; gap:10px;">

                    <!-- Expiry Filter -->
                    <form method="get" id="expiryForm">
                        <input type="hidden" name="search" value="@Model.SearchTerm" />
                        <select name="expiryFilter" onchange="this.form.submit()" style="
                padding: 8px 14px;
                border: 1px solid #ddd;
                border-radius: 8px;
                font-size: 14px;
                cursor: pointer;
                background: #fff;
                color: #333;">
                            <option value="">All Medicines</option>
                            <option value="30" selected="@(Model.ExpiryFilter == 30 ? "selected" : null)"></option>
                            <option value="60" selected="@(Model.ExpiryFilter == 60 ? "selected" : null)"></option>
                            <option value="90" selected="@(Model.ExpiryFilter == 90 ? "selected" : null)"></option>

                        </select>
                    </form>
                     <form method="get" id="stockForm">
        <input type="hidden" name="search" value="@Model.SearchTerm" />
        <input type="hidden" name="expiryFilter" value="@Model.ExpiryFilter" />
        <select name="stockFilter" onchange="this.form.submit()" style="
            padding: 8px 14px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
            cursor: pointer;
            background: #fff;
            color: #333;">
            <option value="">All Stock</option>
            <option value="low" selected="@(Model.StockFilter == "low" ? "selected" : null)"></option>
            <option value="out" selected="@(Model.StockFilter == "out" ? "selected" : null)"></option>
        </select>
    </form>



                    <!-- Add Medicine Button -->
                    <button type="button" class="btn-add" id="openAddMedicine">
                        + Add Medicine
                    </button>

                </div>
            </div>

            <!-- Search bar ALAG neeche rakho — card-header ke bahar -->
            <form method="get" class="search-bar">
                <div class="search-input">
                    <span class="search-icon">🔍</span>
                    <input type="text" name="search" value="@Model.SearchTerm" placeholder="Search medicine name" />
                  
                    <input type="hidden" name="expiryFilter" value="@Model.ExpiryFilter" />
                    <input type="hidden" name="stockFilter" value="@Model.StockFilter" /> <!-- ✅ ADD -->

                    <button type="submit" class="btn-search">Search</button>
                </div>
            </form>
            <table class="sales-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Batch</th>
                        <th>MFG</th>
                        <th>Expiry</th>
                        <th>Stock</th>
                        <th>Low Limit</th>
                        <th>Buy ₹</th>
                        <th>Sell ₹</th>
                        <th>GST %</th>      <!-- ✅ ADD -->
                        <th>Supplier</th>
                        <th>Action</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var med in Model.Medicines)
                    {
                        var isLowStock = med.StockUnits <= med.LowStockLimit;
                        var isExpired = med.ExpiryDate.Date < DateTime.Today;

                        <tr class="@(isLowStock && !isExpired ? "low-stock-row" : "")">
                            <td>@med.MedicineName</td>
                            <td>@med.Category</td>
                            <td>@med.BatchNo</td>
                            <td>@med.MfgDate.ToString("MM/yyyy")</td>
                            <td>@med.ExpiryDate.ToString("MM/yyyy")</td>
                            <td class="stock-cell @(isLowStock && !isExpired ? "low-stock" : "")">
                                @med.StockUnits
                                @if (isLowStock && !isExpired)
                                {
                                    <span class="stock-tooltip">
                                        ⚠ This medicine is low in stock
                                    </span>
                                }
                            </td>
                            <td>@med.LowStockLimit</td>
                            <td>@med.BuyingPrice</td>
                            <td>@med.SellingPrice</td>
                            <td>@med.GstPercent %</td>    <!-- ✅ ADD -->
                            <td>@med.SupplierName</td>
                            <td>
                                @if (med.ExpiryDate.Date < DateTime.Today)
                                {
                                    <form method="post" asp-page-handler="DeleteMedicine" style="display:inline;">
                                        <input type="hidden" name="id" value="@med.Id" />
                                        <button type="submit"
                                                class="btn-delete"
                                                onclick="return confirm('Delete this expired medicine permanently?')">
                                            Delete
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button type="button"
                                            class="btn-update"
                                            onclick="openEditModal(this)"
                                            data-id="@med.Id"
                                            data-name="@med.MedicineName"
                                            data-category="@med.Category"
                                            data-batch="@med.BatchNo"
                                            data-mfg="@med.MfgDate.ToString("yyyy-MM-dd")"
                                            data-stock="@med.StockUnits"
                                            data-low="@med.LowStockLimit"
                                            data-buy="@med.BuyingPrice"
                                            data-sell="@med.SellingPrice"
                                            data-hsn="@med.HsnSac"
                                            data-mode="@med.SellType"
                                            data-gst="@med.GstPercent"
                                            data-supplier="@med.SupplierName"
                                            data-units="@med.UnitsPerStrip"
                                            data-expiry="@med.ExpiryDate.ToString("yyyy-MM-dd")">
                                        Update
                                    </button>
                                }
                            </td>
                            <td>
                                @if (med.ExpiryDate.Date < DateTime.Today)
                                {
                                    <span class="status-expired">Expired</span>
                                }
                                else if (med.StockUnits == 0)
                                {
                                    <span class="status-inactive">Out of Stock</span>
                                }
                                else if (med.StockUnits <= med.LowStockLimit)
                                {
                                    <span class="status-low">Low Stock</span>
                                }
                                else
                                {
                                    <span class="status-active">Active</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>

<!-- ================= MODAL ================= -->

<div class="modal-overlay" id="medicineModal">
    <div class="modal-box">

        <div class="modal-header">
            <h2 id="modalTitle">Add New Medicine</h2>
            <span class="close-btn" id="closeMedicineModal">&times;</span>
        </div>

        <form method="post"
              asp-page-handler="SaveMedicine"
              class="medicine-form"
              id="medicineForm">
            @Html.AntiForgeryToken()
            <!-- HIDDEN ID -->
            <input asp-for="Medicine.Id" type="hidden" id="MedicineId" />

            <div class="form-grid">

                <div>
                    <label>Medicine Name</label>
                    <input asp-for="Medicine.MedicineName" required />
                </div>

                <div>
                    <label>Category</label>
                    <input asp-for="Medicine.Category" required />
                </div>

                <div>
                    <label>Batch No</label>
                    <input asp-for="Medicine.BatchNo" required />
                </div>

                <div>
                    <label>MFG Date</label>
                    <input asp-for="Medicine.MfgDate" type="date" required />
                </div>

                <div>
                    <label>Total Stock Units</label>
                    <input asp-for="Medicine.StockUnits" type="number" required />
                </div>

                <div>
                    <label>Low Stock Limit</label>
                    <input asp-for="Medicine.LowStockLimit" type="number" required />
                </div>

                <div>
                    <label>Buying Price</label>
                    <input asp-for="Medicine.BuyingPrice" type="number" step="0.01" required />
                </div>

                <div>
                    <label>Selling Price (per unit)</label>
                    <input asp-for="Medicine.SellingPrice" type="number" step="0.01" required />
                </div>

                <div>
                    <label>HSN</label>
                    <input asp-for="Medicine.HsnSac" required />
                </div>
                <div>
                    <label>GST %</label>
                    <input asp-for="Medicine.GstPercent" type="number" step="0.01" min="0" max="100" placeholder="e.g. 18" />
                </div>

                <div>
                    <label>Supplier Name</label>
                    <input asp-for="Medicine.SupplierName" type="text" placeholder="e.g. Sun Pharma" />
                </div>

                <div>
                    <label>Selling Mode</label>
                    <select asp-for="Medicine.SellType" id="sellTypeSelect">
                        <option value="Unit">Unit</option>
                        <option value="Strip">Strip</option>
                        <option value="Both">Both</option>
                    </select>
                </div>

                <!-- ✅ NEW: Units Per Strip Field -->
                <div id="unitsPackField">
                    <label>Units Per Strip</label>
                    <input asp-for="Medicine.UnitsPerStrip" type="number" id="unitsPackInput" min="1" value="1" required />
                </div>

                <div>
                    <label>Expiry Date</label>
                    <input asp-for="Medicine.ExpiryDate" type="date" required />
                </div>

            </div>

            <button type="submit" class="btn-save">
                Save Medicine
            </button>

        </form>
    </div>
</div>

<!-- ================= SCRIPT ================= -->
<script>

    const medicineModal = document.getElementById("medicineModal");
    const openBtn = document.getElementById("openAddMedicine");
    const closeBtn = document.getElementById("closeMedicineModal");
    const sellTypeSelect = document.getElementById("sellTypeSelect");
    const unitsPackField = document.getElementById("unitsPackField");
    const unitsPackInput = document.getElementById("unitsPackInput");

    medicineModal.style.display = "none";

    // ✅ Toggle Units Per Strip Field
    function toggleUnitsPack() {
        if (sellTypeSelect.value === "Unit") {
            unitsPackField.style.display = "none";
            unitsPackInput.value = 1;
        } else {
            unitsPackField.style.display = "block";
        }
    }

        // ✅ Open Modal — Add Mode
    openBtn.onclick = () => {
        document.getElementById("modalTitle").innerText = "Add New Medicine";
        document.getElementById("MedicineId").value = "0";

        document.querySelector('[name="Medicine.MedicineName"]').value  = "";
        document.querySelector('[name="Medicine.Category"]').value      = "";
        document.querySelector('[name="Medicine.BatchNo"]').value       = "";
        document.querySelector('[name="Medicine.MfgDate"]').value       = "";
        document.querySelector('[name="Medicine.StockUnits"]').value    = "";
        document.querySelector('[name="Medicine.LowStockLimit"]').value = "";
        document.querySelector('[name="Medicine.BuyingPrice"]').value   = "";
        document.querySelector('[name="Medicine.SellingPrice"]').value  = "";
        document.querySelector('[name="Medicine.HsnSac"]').value        = "";
        document.querySelector('[name="Medicine.GstPercent"]').value    = "";
        document.querySelector('[name="Medicine.SupplierName"]').value  = "";
        document.querySelector('[name="Medicine.ExpiryDate"]').value    = "";
        document.querySelector('[name="Medicine.SellType"]').value      = "Unit";
        unitsPackInput.value = "1";

        toggleUnitsPack();
        medicineModal.style.display = "flex";
    };
    // ✅ Close Modal
    closeBtn.onclick = () => {
        medicineModal.style.display = "none";
    };

    // ✅ Close Outside Click
    window.onclick = (e) => {
        if (e.target === medicineModal) {
            medicineModal.style.display = "none";
        }
    };

    // ✅ On Dropdown Change
    sellTypeSelect.addEventListener("change", toggleUnitsPack);
    toggleUnitsPack();

        // ✅ Edit Modal — set ALL values before calling toggleUnitsPack
    function openEditModal(button) {
        document.getElementById("modalTitle").innerText = "Update Medicine";
        document.getElementById("MedicineId").value = button.dataset.id;
        document.querySelector('[name="Medicine.MedicineName"]').value  = button.dataset.name;
        document.querySelector('[name="Medicine.Category"]').value      = button.dataset.category;
        document.querySelector('[name="Medicine.BatchNo"]').value       = button.dataset.batch;
        document.querySelector('[name="Medicine.MfgDate"]').value       = button.dataset.mfg;
        document.querySelector('[name="Medicine.StockUnits"]').value    = button.dataset.stock;
        document.querySelector('[name="Medicine.LowStockLimit"]').value = button.dataset.low;
        document.querySelector('[name="Medicine.BuyingPrice"]').value   = button.dataset.buy;
        document.querySelector('[name="Medicine.SellingPrice"]').value  = button.dataset.sell;
        document.querySelector('[name="Medicine.HsnSac"]').value        = button.dataset.hsn;
        document.querySelector('[name="Medicine.GstPercent"]').value    = button.dataset.gst;
        document.querySelector('[name="Medicine.SupplierName"]').value  = button.dataset.supplier;
        document.querySelector('[name="Medicine.ExpiryDate"]').value    = button.dataset.expiry;
        // Set SellType FIRST, then UnitsPerStrip, then toggle
        sellTypeSelect.value  = button.dataset.mode;
        unitsPackInput.value  = button.dataset.units || 1;
        toggleUnitsPack();
        medicineModal.style.display = "flex";
    }

</script>

<div class="pagination">

    @if (Model.CurrentPage > 1)
    {
        <a class="page-btn"
           asp-page="/TotalMedicine"
           asp-route-pageNumber="@(Model.CurrentPage - 1)"
           asp-route-search="@Model.SearchTerm"
           asp-route-expiryFilter="@Model.ExpiryFilter"
           asp-route-stockFilter="@Model.StockFilter"> <!-- ✅ ADD THIS -->
            ⬅ Previous
        </a>
    }

    <span class="page-info">
        Page @Model.CurrentPage of @Model.TotalPages
    </span>

    @if (Model.CurrentPage < Model.TotalPages)
    {
        <a class="page-btn"
           asp-page="/TotalMedicine"
           asp-route-pageNumber="@(Model.CurrentPage + 1)"
           asp-route-search="@Model.SearchTerm"
           asp-route-expiryFilter="@Model.ExpiryFilter">
            Next ➡
        </a>
    }

</div>