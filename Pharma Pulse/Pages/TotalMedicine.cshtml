@page
@model Pharma_Pulse.Pages.TotalMedicineModel

@{
    ViewData["Title"] = "TotalMedicines";
}

<link rel="stylesheet" href="~/css/medicine.css" />

<div class="dashboard-container">

    <!-- LEFT SIDEBAR -->
    <div class="sidebar">
    <h2 class="sidebar-title">Pharma Pulse</h2>

    <ul class="sidebar-menu">

        <li>
            <a asp-page="/Dashboard" class="menu-link">
                🏠 Dashboard
            </a>
        </li>

        <li>
            <a asp-page="/SalesSummary" class="menu-link">
                📊 Sales Summary
            </a>
        </li>

        <li>
            <a asp-page="/QuickBilling" class="menu-link">
                💵 Quick Billing
            </a>
        </li>

        <li>
                <a asp-page="/TotalMedicine" class="menu-link active">
                💊 Medicines
            </a>
        </li>

        <li>
            <a asp-page="/LowStockAlerts" class="menu-link">
                ⚠ Low Stock Alerts
            </a>
        </li>

        <li>
            <a asp-page="/ExpiryAlerts" class="menu-link">
                ⏳ Expiry Alerts
            </a>
        </li>

    </ul>
</div>


    <!-- MAIN CONTENT -->
    <div class="main-content">

        <div class="content-card">

            <!-- Header -->
            <div class="card-header">
                <h2>Available Medicines</h2>
                <button class="btn-add">+ Add Medicine</button>
            </div>

            <!-- Search + Entries -->
            <div class="table-top">
                <input type="text" placeholder="🔍 Search medicines..." />

                <div class="entries">
                    Showing 1-10 of 250
                    <select>
                        <option>10</option>
                        <option>25</option>
                        <option>50</option>
                    </select>
                </div>
            </div>

            <!-- Table -->
            <table>
                <thead>
                    <tr>
                        <th>Medicine Name</th>
                        <th>Category</th>
                        <th>Stock</th>
                        <th>Expiry Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var med in Model.Medicines)
                    {
                        <tr>
                            <td>@med.MedicineName</td>
                            <td>@med.Category</td>
                            <td>@med.Stock</td>
                            <td>@med.ExpiryDate.ToShortDateString()</td>
                            <td>
                                <button class="btn-edit">Edit</button>
                                <button class="btn-delete">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination -->
            <div class="pagination">
                <button>Previous</button>
                <button class="active">1</button>
                <button>2</button>
                <button>3</button>
                <button>Next</button>
            </div>

        </div>
    </div>
</div>
