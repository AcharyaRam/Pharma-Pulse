@page
@model Pharma_Pulse.Pages.BillModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Invoice</title>

    <style>
        body {
            font-family: Arial;
            padding: 30px;
        }

        .invoice-container {
            width: 800px;
            margin: auto;
            border: 2px solid black;
            padding: 25px;
        }

        .header {
            display: flex;
            justify-content: space-between;
        }

        .store-name {
            font-size: 24px;
            font-weight: bold;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        table, th, td {
            border: 1px solid black;
        }

        th, td {
            padding: 10px;
            text-align: center;
        }

        .totals {
            text-align: right;
            margin-top: 20px;
        }

        .footer {
            text-align: center;
            margin-top: 40px;
        }

        button {
            margin-top: 20px;
            padding: 10px 20px;
        }

        @@media print {
            button {
                display: none;
            }
        }
    </style>
</head>

<body>

    <div class="invoice-container">

        <!-- HEADER -->
        <div class="header">
            <div>
                <div class="store-name">PHARMA PULSE</div>
                Near City Hospital, Mumbai <br />
                GST No: 27ABCDE1234F1Z5
            </div>

            <div>
                Invoice: <b>@Model.InvoiceNumber</b> <br />
                Date: @DateTime.Now.ToString("dd-MM-yyyy HH:mm")
            </div>
        </div>

        <hr />

        <!-- CUSTOMER -->
        <p>
            <b>Customer:</b> @Model.CustomerName <br />
            <b>Mobile:</b> @Model.MobileNumber
        </p>

        <!-- ITEMS TABLE -->
        <table>
            <thead>
                <tr>
                    <th>Medicine</th>
                    <th>Qty</th>
                    <th>Price</th>
                    <th>Total</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.BillItems)
                {
                    <tr>
                        <td>@item.MedicineName</td>
                        <td>@item.Quantity</td>
                        <td>₹@item.Price.ToString("0.00")</td>
                        <td>₹@item.Total.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- TOTALS -->
        <div class="totals">

            <p><b>Subtotal:</b> ₹@Model.SubTotal.ToString("0.00")</p>

            <p>
                <b>GST (@Model.GstPercent% Total)</b>
            </p>

            <p>
                CGST (@(Model.GstPercent / 2)%):
                ₹@Model.CGST.ToString("0.00")
            </p>

            <p>
                SGST (@(Model.GstPercent / 2)%):
                ₹@Model.SGST.ToString("0.00")
            </p>

            <hr />

            <h2>
                Grand Total: ₹@Model.GrandTotal.ToString("0.00")
            </h2>

        </div>

        <!-- FOOTER -->
        <div class="footer">
            Thank You! Visit Again 🙏
        </div>

        <!-- BUTTONS -->
        <form method="post">
            <button type="button" onclick="window.print()">Print</button>
            <button asp-page-handler="Finish">Finish</button>
        </form>

    </div>

    <script>
        window.onload = function () {
            window.print();
        }
    </script>

</body>
</html>
